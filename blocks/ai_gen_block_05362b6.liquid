{% doc %}
  @prompt
    masonry style collage gallery with interactive hero images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-masonry-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-masonry-gallery__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_size }}px;
    width: 100%;
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    cursor: pointer;
    break-inside: avoid;
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-row: span {{ block.settings.item_1_height }};
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-row: span {{ block.settings.item_2_height }};
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-row: span {{ block.settings.item_3_height }};
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-row: span {{ block.settings.item_4_height }};
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(5) {
    grid-row: span {{ block.settings.item_5_height }};
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(6) {
    grid-row: span {{ block.settings.item_6_height }};
  }

  .ai-masonry-gallery__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: block;
  }

  .ai-masonry-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, filter 0.5s ease;
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:hover .ai-masonry-gallery__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.hover_zoom }});
    filter: brightness({{ block.settings.hover_brightness }});
  }

  .ai-masonry-gallery__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_color }};
    opacity: 0;
    transition: opacity 0.5s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:hover .ai-masonry-gallery__overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-masonry-gallery__overlay-content-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.overlay_text_color }};
    padding: 20px;
    transform: translateY(20px);
    transition: transform 0.5s ease;
  }

  .ai-masonry-gallery__item-{{ ai_gen_id }}:hover .ai-masonry-gallery__overlay-content-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .ai-masonry-gallery__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .ai-masonry-gallery__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-masonry-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-masonry-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-masonry-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-masonry-gallery__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_size | times: 0.7 }}px;
    }

    .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(4),
    .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(5),
    .ai-masonry-gallery__item-{{ ai_gen_id }}:nth-child(6) {
      grid-row: span 1;
    }

    .ai-masonry-gallery__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-masonry-gallery__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<masonry-gallery-{{ ai_gen_id }}
  class="ai-masonry-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-masonry-gallery__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        assign link_key = 'link_' | append: i

        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign link = block.settings[link_key]
      %}

      <div class="ai-masonry-gallery__item-{{ ai_gen_id }}" data-index="{{ i }}">
        {% if link != blank %}
          <a href="{{ link }}" class="ai-masonry-gallery__image-wrapper-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-masonry-gallery__image-wrapper-{{ ai_gen_id }}">
        {% endif %}

          {% if image %}
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-masonry-gallery__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-masonry-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              {% if i == 1 %}
                <div class="ai-masonry-gallery__empty-state-{{ ai_gen_id }}">
                  Add images to create your gallery
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if title != blank or description != blank %}
            <div class="ai-masonry-gallery__overlay-{{ ai_gen_id }}">
              <div class="ai-masonry-gallery__overlay-content-{{ ai_gen_id }}">
                {% if title != blank %}
                  <h3 class="ai-masonry-gallery__title-{{ ai_gen_id }}">{{ title }}</h3>
                {% endif %}
                {% if description != blank %}
                  <p class="ai-masonry-gallery__description-{{ ai_gen_id }}">{{ description }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}

        {% if link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</masonry-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class MasonryGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-masonry-gallery__item-{{ ai_gen_id }}');
        this.setupInteractivity();
      }

      setupInteractivity() {
        this.items.forEach((item) => {
          item.addEventListener('mouseenter', () => {
            this.items.forEach((otherItem) => {
              if (otherItem !== item) {
                otherItem.style.opacity = '0.7';
              }
            });
          });

          item.addEventListener('mouseleave', () => {
            this.items.forEach((otherItem) => {
              otherItem.style.opacity = '1';
            });
          });
        });
      }
    }

    customElements.define('masonry-gallery-{{ ai_gen_id }}', MasonryGallery{{ ai_gen_id }});
  })();
</script>

