{% doc %}
  @prompt
    gallery
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-gallery-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
  }

  .ai-gallery-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-gallery-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  .ai-gallery-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover .ai-gallery-overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-gallery-title-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.title_font_size }}px;
    margin: 0 0 5px 0;
    font-weight: 600;
  }

  .ai-gallery-description-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.description_font_size }}px;
    margin: 0;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-gallery-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #666;
    text-align: center;
    padding: 0 10px;
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-gallery-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.85 }}px;
    }

    .ai-gallery-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<gallery-block-{{ ai_gen_id }} class="ai-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gallery-container-{{ ai_gen_id }}">
    {% for i in (1..9) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        assign link_key = 'link_' | append: i

        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign link = block.settings[link_key]
      %}

      {% if image != blank or forloop.index <= 6 %}
        <div class="ai-gallery-item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}">
          {% endif %}

          {% if image != blank %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          {% else %}
            <div class="ai-gallery-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-gallery-empty-state-{{ ai_gen_id }}">
                Add image {{ forloop.index }}
              </div>
            </div>
          {% endif %}

          {% if block.settings.show_overlay and image != blank %}
            {% if title != blank or description != blank %}
              <div class="ai-gallery-overlay-{{ ai_gen_id }}">
                {% if title != blank %}
                  <h3 class="ai-gallery-title-{{ ai_gen_id }}">{{ title }}</h3>
                {% endif %}
                {% if description != blank %}
                  <p class="ai-gallery-description-{{ ai_gen_id }}">{{ description }}</p>
                {% endif %}
              </div>
            {% endif %}
          {% endif %}

          {% if link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</gallery-block-{{ ai_gen_id }}>

<script>
  (function() {
    class GalleryBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-gallery-item-{{ ai_gen_id }}');
      }
    }

    customElements.define('gallery-block-{{ ai_gen_id }}', GalleryBlock{{ ai_gen_id }});
  })();
</script>

