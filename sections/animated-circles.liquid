			        },
					{
						"type": "url",
						"id": "url",
						"label": "Link"
					}
					
				]
			}
		],
	    "presets": [
			{
				"category": "Content",
				"name": "Animated circles",
				"settings": {},
				"blocks": [
					{
						"type": "item"
					},
					{
						"type": "item"
					}
				]
			}
		]
	}
