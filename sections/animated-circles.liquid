{%- capture section_content -%}
	{%- capture text_content -%}
		{%- if section.settings.subheading != blank -%}
			<h3 class="SectionHeader__SubHeading Heading Heading--caps Heading--textFont u-h6"><span>{{ section.settings.subheading }}</span></h3>
		{%- endif -%}

		{%- if section.settings.title != blank -%}
			<h2 class="SectionHeader__Heading Heading u-h3"><span>{{ section.settings.title }}</span></h2>
		{%- endif -%}

		{%- if section.settings.description != blank -%}
			<div class="SectionHeader__Description SectionHeader__Description--primary Rte">
				{{ section.settings.description }}
			</div>
		{%- endif -%}

		{%- if section.settings.button_1_text != blank and section.settings.button_2_text != blank -%}
			{%- assign has_two_buttons = true -%}
		{%- else -%}
			{%- assign has_two_buttons = false -%}
		{%- endif -%}

		{%- if section.settings.button_1_text != blank or section.settings.button_2_text != blank -%}
			<div class="SectionHeader__ButtonWrapper">
				<div class="ButtonGroup ButtonGroup--spacingSmall {% if has_two_buttons %}ButtonGroup--sameSize{% endif %}">
					{%- if section.settings.button_1_text != blank -%}
						<a href="{{ section.settings.button_1_link }}" class="ButtonGroup__Item {% if section.settings.button_style == 'underline' %}Link Link--underline{% else %}Button Button--{{ section.settings.button_style }}{% endif %}">{{ section.settings.button_1_text | escape }}</a>
					{%- endif -%}

					{%- if section.settings.button_2_text != blank -%}
						<a href="{{ section.settings.button_2_link }}" class="ButtonGroup__Item {% if section.settings.button_style == 'underline' %}Link Link--underline{% else %}Button Button--{{ section.settings.button_style }}{% endif %}">{{ section.settings.button_2_text | escape }}</a>
					{%- endif -%}
				</div>
			</div>
		{%- endif -%}
	{%- endcapture -%}

	{%- if text_content != blank -%}
		<div class="AnimatedCircles__ContentWrapper">
			<div class="AnimatedCircles__Content ColourStyle--{{ section.settings.colour_style }}">
				<header class="SectionHeader SectionHeader--center">
					{{ text_content }}
				</header>
			</div>
		</div>
	{%- endif -%}
{%- endcapture -%}

{%- capture content_items -%}
	<div class="AnimatedCirclesList__Wrapper">
		
		{%- assign media = section.settings.image -%}
		<div class="AnimatedCirclesListWrapper__ImageWrapper AspectRatio AspectRatio--withFallback" style="padding-bottom: {{ 100.0 | divided_by: media.aspect_ratio }}%; --aspect-ratio: {{ media.aspect_ratio }};">
			{%- assign image_url = media | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
	        {%- capture supported_sizes -%}{%- render 'image-size', sizes: '200,300,400,500,600', image: media -%}{%- endcapture -%}
	
			<img class="AnimatedCirclesListWrapper__Image Image--fadeIn Image--lazyLoad hide-no-js"
				data-src="{{ image_url }}"
				data-optimumx="1.2"
				data-widths="[{{ supported_sizes }}]"
				data-sizes="auto"
				alt="{{ media.alt | escape }}">

			<noscript>
				<img class="AnimatedCirclesListWrapper__Image" src="{{ media | img_url: '300x' }}" alt="{{ media.alt | escape }}">
			</noscript>
		</div>
		
		{%- for block in section.blocks -%}
			<div class="AnimatedCirclesList__Item Text--alignCenter">
				{%- if block.settings.url != blank -%}
					<a href="{{ block.settings.url }}">
				{%- endif -%}
					{%- assign media = block.settings.image -%}
					<div class="AnimatedCirclesListItem__ImageWrapper AspectRatio AspectRatio--withFallback" style="padding-bottom: {{ 100.0 | divided_by: media.aspect_ratio }}%; --aspect-ratio: {{ media.aspect_ratio }};">
						{%- assign image_url = media | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
				        {%- capture supported_sizes -%}{%- render 'image-size', sizes: '200,400,600', image: media -%}{%- endcapture -%}
				
						<img class="AnimatedCirclesListItem__Image Image--fadeIn Image--lazyLoad hide-no-js"
							data-src="{{ image_url }}"
							data-optimumx="1.2"
							data-widths="[{{ supported_sizes }}]"
							data-sizes="auto"
							alt="{{ media.alt | escape }}">

						<noscript>
							<img class="AnimatedCirclesListItem__Image" src="{{ media | img_url: '200x' }}" alt="{{ media.alt | escape }}">
						</noscript>
					</div>
					
					{%- if block.settings.title != blank -%}
						<h3 class="Heading u-h6">{{ block.settings.title }}</h3>
					{%- endif -%}
					
				{%- if block.settings.url != blank -%}
					</a>
				{%- endif -%}
			</div>
		{%- endfor -%}
	</div>
{%- endcapture -%}

{%- if content_items != blank -%}
	<section class="Section Section--spacingExtraLarge" id="section-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="animated-circles">
		<div class="Container">
			{%- if section_content != blank -%}
				{{ section_content }}
			{%- endif -%}
			{{ content_items }}
		</div>
	</section>
	
	<style>
		.AnimatedCirclesList__Item {
		    width: 15%;
		    position: absolute;
			transition: opacity 0.5s ,transform 2s;
		    left: calc(100% * 0.5 * 0.85);
		    top: calc(100% * 0.5 * 0.85);
			opacity: 0;
		}

		.AnimatedCirclesList__Wrapper {
		    width: 300px;
		    height: 300px;
		    position: relative;
		    display: flex;
		    justify-content: center;
		    align-items: center;
		    margin: 50px auto;
		}
		
		.AnimatedCirclesListWrapper__ImageWrapper {
		    width: 150px;
		    height: 150px;
		}
		
		.AnimatedCirclesList__Item h3 {
		    position: absolute;
		    padding-top: 10px;
		    left: 50%;
		    transform: translateX(-50%);
		}
		
		@media screen and (min-width: 641px) {
			.AnimatedCirclesList__Wrapper {
			    width: 500px;
			    height: 500px;
			}
		
			.AnimatedCirclesListWrapper__ImageWrapper {
			    width: 250px;
			    height: 250px;
			}
		}
	</style>	
{%- endif -%}	



{% schema %}
	{
