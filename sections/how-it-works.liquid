<section class="how-it-works-section">
  <div class="Container">

    {% if section.settings.heading != blank %}
      <h2 class="how-it-works-heading Heading u-h3">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <div class="how-it-works-subheading">
        {{ section.settings.subheading }}
      </div>
    {% endif %}

    <div class="how-it-works-grid">
      {% for block in section.blocks %}
        {% assign article = block.settings.article %}

        <div
          class="how-it-works-card"
          {{ block.shopify_attributes }}
        >

          {% if article %}
            <a
              href="{{ article.url }}"
              class="how-it-works-image-link"
            >
          {% endif %}

          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'how-it-works-image'
            }}
          {% elsif article and article.image %}
            {{
              article.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'how-it-works-image'
            }}
          {% endif %}

          {% if article %}
            </a>
          {% endif %}

          <div class="how-it-works-content">

            {% if article %}
              <h3 class="how-it-works-title ProductItem__Title Heading u-h5">
                <a href="{{ article.url }}">
                  {{ article.title }}
                </a>
              </h3>
            {% elsif block.settings.custom_title != blank %}
              <h3 class="how-it-works-title ProductItem__Title Heading u-h5">
                {{ block.settings.custom_title }}
              </h3>
            {% endif %}

            {% if block.settings.custom_text != blank %}
              <div class="how-it-works-text">
                {{ block.settings.custom_text }}
              </div>
            {% elsif article and article.excerpt != blank %}
              <div class="how-it-works-text">
                {{ article.excerpt }}
              </div>
            {% endif %}

           

          </div>

        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
    .how-it-works-title.ProductItem__Title.Heading.u-h5 {
	min-height: auto;
}
.how-it-works-section {
  padding: 60px 0;
}

.how-it-works-heading {
  text-align: left;
}

.how-it-works-subheading {
  text-align: left;
  margin: 5px auto 30px;
}
.how-it-works-subheading p {
	font-size: 18px;
}
.how-it-works-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}

.how-it-works-card {
  display: flex;
  flex-direction: column;
}

.how-it-works-image-link {
  display: block;
  overflow: hidden;
}

.how-it-works-image {
  width: 100%;
  height: auto;
  display: block;
  transition: transform .3s ease;
}

.how-it-works-card:hover .how-it-works-image {
  transform: scale(1.03);
}

.how-it-works-content {
  padding-top: 18px;
}

.how-it-works-title {
  margin: 0 0 12px;
  font-size: 22px;
  line-height: 1.3;
}

.how-it-works-title a {
  text-decoration: none;
  color: inherit;
}

.how-it-works-text {
  margin-bottom: 16px;
  font-size: 15px;
  line-height: 1.6;
}

.how-it-works-button {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  font-weight: 600;
}
@media screen and (min-width: 641px) {
.Product {
	margin-bottom: 40px !important;
}
}
@media screen and (max-width: 989px) {
  .how-it-works-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 749px) {
  .how-it-works-section {
    padding: 40px 0;
  }
.how-it-works-subheading p{
   font-size: 12px;
}
  .how-it-works-heading {
	font-size: 18px !important;
}

  .how-it-works-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}
@media screen and (max-width: 749px) {
.Product {
	margin: 0 auto 25px;
}
}
</style>

{% schema %}
{
  "name": "How It Works Articles",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How does STM work?"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    }
  ],
  "blocks": [
    {
      "type": "article_card",
      "name": "Article Card",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Select Blog Article"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (Optional)"
        },
        {
          "type": "richtext",
          "id": "custom_text",
          "label": "Custom Description (Optional)"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "How It Works Articles",
      "blocks": [
        {
          "type": "article_card"
        },
        {
          "type": "article_card"
        },
        {
          "type": "article_card"
        }
      ]
    }
  ]
}
{% endschema %}