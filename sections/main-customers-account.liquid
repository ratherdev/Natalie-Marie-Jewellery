<div class="Container Container--narrow">
  
  <header class="PageHeader" {{ block.shopify_attributes }}>
    <a href="{{ routes.account_logout_url }}" class="PageHeader__Back Heading Heading--caps Heading--textFont u-h6"><span><strong>{{ 'customer.account.logout' | t }}</strong></span></a>

    <div class="SectionHeader">
      <h1 class="SectionHeader__Heading Heading u-h3">
		  {%- assign titleArray = 'customer.account.title' | t | split: ' ' -%}
		  <span>
			  {%- for word in titleArray -%}
			  	{%- if forloop.last -%}
					<em>{{ word }}</em>
				{%- else -%}	
					{{ word | append: ' ' }}
				{%- endif -%}
			  {%- endfor -%}
		  </span>
	  </h1>
	  
      <p class="SectionHeader__Description">{{ 'customer.account.welcome' | t: first_name: customer.first_name }}</p>
    </div>
  </header>
  
  <div class="Grid Grid--m">
  
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {%- render block -%}
		
        {%- when 'account_info' -%}
            {%- comment -%}
            --------------------------------------------------------------------------------------------------------------------
            ACCOUNT INFO
            --------------------------------------------------------------------------------------------------------------------
            {%- endcomment -%}

            <div class="Grid__Cell 1/3--lap-and-up">
              <div class="Segment Segment--boxed">
                  <h2 class="Segment__Title Heading u-h3">
					  {%- assign titleArray = 'customer.account.account_information' | t | split: ' ' -%}
					  <span>
						  {%- for word in titleArray -%}
						  	{%- if forloop.last -%}
								<em>{{ word }}</em>
							{%- else -%}	
								{{ word | append: ' ' }}
							{%- endif -%}
						  {%- endfor -%}
					  </span>
				  </h2>

                  <div class="Segment__Content">
                    <p>
						{{ customer.name }}
						<br>
						{{ customer.email }}
					</p>
                    
                  </div>
                
              </div>
            </div>
			
	  	{%- when 'address_book' -%}
            {%- comment -%}
            --------------------------------------------------------------------------------------------------------------------
            ADDRESS BOOK
            --------------------------------------------------------------------------------------------------------------------
            {%- endcomment -%}

            <div class="Grid__Cell 1/3--lap-and-up">
              <div class="Segment Segment--boxed">
                  <h2 class="Segment__Title Heading u-h3">
					  {%- assign titleArray = 'customer.account.address_book' | t | split: ' ' -%}
					  <span>
						  {%- for word in titleArray -%}
						  	{%- if forloop.last -%}
								<em>{{ word }}</em>
							{%- else -%}	
								{{ word | append: ' ' }}
							{%- endif -%}
						  {%- endfor -%}
					  </span>
				  </h2>

                  <div class="Segment__Content">
                    <p>{{ 'customer.account.address_book_content' | t }}</p>

                    <div class="Segment__ButtonWrapper">
                      <a href="{{ routes.account_addresses_url }}" class="Link Link--underline Link--primary">{{ 'customer.account.manage_addresses' | t }}</a>
                    </div>
                  </div>
              </div>
            </div>	
	  
	  	{%- when 'default_address' -%}
            {%- comment -%}
            --------------------------------------------------------------------------------------------------------------------
            DEFAULT ADDRESS
            --------------------------------------------------------------------------------------------------------------------
            {%- endcomment -%}

            <div class="Grid__Cell 1/3--lap-and-up">
              <div class="Segment Segment--boxed">
                {%- if customer.addresses_count == 0 -%}
                  <h2 class="Segment__Title Heading u-h3">
					  {%- assign titleArray = 'customer.account.default_address' | t | split: ' ' -%}
					  <span>
						  {%- for word in titleArray -%}
						  	{%- if forloop.last -%}
								<em>{{ word }}</em>
							{%- else -%}	
								{{ word | append: ' ' }}
							{%- endif -%}
						  {%- endfor -%}
					  </span>
				  </h2>

                  <div class="Segment__Content">
                    <p>{{ 'customer.account.no_addresses_content' | t }}</p>

                    <div class="Segment__ButtonWrapper">
                      <a href="{{ routes.account_addresses_url }}" class="Link Link--underline Link--primary">{{ 'customer.account.manage_addresses' | t }}</a>
                    </div>
                  </div>
                {%- else -%}
                  <h2 class="Segment__Title Heading u-h3">
					  {%- assign titleArray = 'customer.account.default_address' | t | split: ' ' -%}
					  <span>
						  {%- for word in titleArray -%}
						  	{%- if forloop.last -%}
								<em>{{ word }}</em>
							{%- else -%}	
								{{ word | append: ' ' }}
							{%- endif -%}
						  {%- endfor -%}
					  </span>
				  </h2>

                  <div class="Segment__Content">
                    {{ customer.default_address | format_address | replace: '<p>', '<p class="AccountAddress"><span>' | replace_first: '<br>', '</span><br>' }}

                    <div class="Segment__ButtonWrapper">
                      <a href="{{ routes.account_addresses_url }}" class="Link Link--underline Link--primary">{{ 'customer.account.manage_addresses' | t }}</a>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>

        {%- when 'order_list' -%}
            {%- comment -%}
            --------------------------------------------------------------------------------------------------------------------
            ORDER HISTORY
            --------------------------------------------------------------------------------------------------------------------
            {%- endcomment -%}

            <div class="Grid__Cell Grid__Cell--expand 1/3--lap-and-up">
              {%- if customer.orders.size == 0 -%}
                <div class="Segment Segment--boxed">
                  <h2 class="Segment__Title Heading u-h3">
					  {%- assign titleArray = 'customer.account.orders_title' | t | split: ' ' -%}
					  <span>
						  {%- for word in titleArray -%}
						  	{%- if forloop.last -%}
								<em>{{ word }}</em>
							{%- else -%}	
								{{ word | append: ' ' }}
							{%- endif -%}
						  {%- endfor -%}
					  </span>
				  </h2>

                  <div class="Segment__Content">
                    <p>{{ 'customer.account.no_orders_content' | t }}</p>
                  </div>
                </div>
              {%- else -%}
                <div class="Segment Segment--boxed">
                  <h2 class="Segment__Title Heading u-h3">
					  {%- assign titleArray = 'customer.account.orders_title' | t | split: ' ' -%}
					  <span>
						  {%- for word in titleArray -%}
						  	{%- if forloop.last -%}
								<em>{{ word }}</em>
							{%- else -%}	
								{{ word | append: ' ' }}
							{%- endif -%}
						  {%- endfor -%}
					  </span>
				  </h2>

                  <div class="Segment__Content">
	                <p>{{ 'customer.account.orders_content' | t }}</p>
					{%- paginate customer.orders by 25 -%}
	                  <div class="TableWrapper">
	                    <table class="AccountTable Table Table--large">
	                      <thead class="">
	                      <tr>
	                        <th>{{ 'customer.orders.order_number' | t }}</th>
	                        <th>{{ 'customer.orders.date' | t }}</th>
	                        <th>{{ 'customer.orders.payment_status' | t }}</th>
	                        <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
	                        <th class="Text--alignRight">{{ 'customer.orders.total' | t }}</th>
	                      </tr>
	                      </thead>

	                      <tbody class="Heading Heading--textFont u-h6">
	                      {%- for order in customer.orders -%}
	                        <tr>
	                          <td><a href="{{ order.customer_url }}" class="Link Link--underline">{{ order.name }}</a></td>
	                          <td>{{ order.created_at | date: format: 'basic' }}</td>
	                          <td>{{ order.financial_status_label }}</td>
	                          <td>{{ order.fulfillment_status_label }}</td>
	                          <td class="Text--alignRight">{{ order.total_price | money }}</td>
	                        </tr>
	                      {%- endfor -%}
	                      </tbody>
	                    </table>
	                  </div>

	                  {%- render 'pagination', paginate: paginate -%}
	                {%- endpaginate -%}
                  </div>
                </div>
              {%- endif -%}
            </div>

      {%- endcase -%}
    {%- endfor -%}
  
  </div>
</div>

{% schema %}
{
  "name": "Customer account",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "header",
      "name": "Welcome info",
      "limit": 1
    },
    {
      "type": "order_list",
      "name": "Order list",
      "limit": 1
    },
    {
      "type": "account_info",
      "name": "Account information",
      "limit": 1
    },
    {
      "type": "address_book",
      "name": "Address book",
      "limit": 1
    },
	{
      "type": "default_address",
      "name": "Default address",
      "limit": 1
    }
  ]
}
{% endschema %}