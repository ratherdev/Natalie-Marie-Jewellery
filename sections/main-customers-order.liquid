{%- assign is_entirely_fulfilled = false -%}
{%- assign has_one_fulfillment = false -%}

{%- if order.fulfillment_status == 'fulfilled' -%}
  {%- assign is_entirely_fulfilled = true -%}
  {%- assign tracking_numbers = '' -%}

  {%- for line_item in order.line_items -%}
    {%- assign tracking_numbers = tracking_numbers | append: line_item.fulfillment.tracking_number | append: ',' -%}
  {%- endfor -%}

  {%- assign tracking_numbers = tracking_numbers | split: ',' | compact | uniq -%}

  {%- if tracking_numbers.size == 1 -%}
    {%- assign has_one_fulfillment = true -%}
  {%- endif -%}
{%- endif -%}

<div class="Container Container--narrow">
	<header class="PageHeader">
		<a href="{{ routes.account_url }}" class="PageHeader__Back Heading Heading--caps Heading--textFont u-h6"><span><strong>{{ 'customer.account.back_to_account' | t }}</strong></span></a>
	    <div class="SectionHeader">
	      <h1 class="SectionHeader__Heading Heading u-h3">
			  {%- assign titleArray = 'customer.order.title' | t: order_number: order.name | split: ' ' -%}
			  <span>
				  {%- for word in titleArray -%}
				  	{%- if forloop.last -%}
						<em>{{ word }}</em>
					{%- else -%}	
						{{ word | append: ' ' }}
					{%- endif -%}
				  {%- endfor -%}
			  </span>
		  </h1>
	    </div>
	</header>
  
	<div class="Grid Grid--m">
		<div class="Grid__Cell 1/3--lap-and-up">
			<div class="Segment Segment--boxed">
				<h2 class="Segment__Title Heading u-h3">
	  			  {%- assign titleArray = 'customer.order.shipping_address' | t | split: ' ' -%}
	  			  <span>
	  				  {%- for word in titleArray -%}
	  				  	{%- if forloop.last -%}
	  						<em>{{ word }}</em>
	  					{%- else -%}	
	  						{{ word | append: ' ' }}
	  					{%- endif -%}
	  				  {%- endfor -%}
	  			  </span>
				</h2>
	            <div class="Segment__Content">
	              {%- if order.shipping_address -%}
	                {{ order.shipping_address | format_address | replace: '<p>', '<p class="AccountAddress"><span>' | replace_first: '<br>', '</span><br>' }}
	              {%- else -%}
	                <p>{{ 'customer.order.no_shipping_address' | t }}</p>
	              {%- endif -%}
	            </div>
			</div>
		</div>
		
		<div class="Grid__Cell 1/3--lap-and-up">
			<div class="Segment Segment--boxed">
				<h2 class="Segment__Title Heading u-h3">
  	  			  {%- assign titleArray = 'customer.order.billing_address' | t | split: ' ' -%}
  	  			  <span>
  	  				  {%- for word in titleArray -%}
  	  				  	{%- if forloop.last -%}
  	  						<em>{{ word }}</em>
  	  					{%- else -%}	
  	  						{{ word | append: ' ' }}
  	  					{%- endif -%}
  	  				  {%- endfor -%}
  	  			  </span>
				</h2>
	            <div class="Segment__Content">
	              {{ order.billing_address | format_address | replace: '<p>', '<p class="AccountAddress"><span>' | replace_first: '<br>', '</span><br>' }}
	            </div>
			</div>
		</div>
		
		{%- if order.fulfillment_status == 'fulfilled' and tracking_numbers.size > 1 -%}
		
			<div class="Grid__Cell 1/3--lap-and-up">
				<div class="Segment Segment--boxed">
					<h2 class="Segment__Title Heading u-h3">
	    	  			  {%- assign titleArray = 'customer.order.tracking_numbers' | t | split: ' ' -%}
	    	  			  <span>
	    	  				  {%- for word in titleArray -%}
	    	  				  	{%- if forloop.last -%}
	    	  						<em>{{ word }}</em>
	    	  					{%- else -%}	
	    	  						{{ word | append: ' ' }}
	    	  					{%- endif -%}
	    	  				  {%- endfor -%}
	    	  			  </span>
					</h2>
		            <div class="Segment__Content">
						{%- for line_item in order.line_items -%}
						
						{%- endfor -%}
		            </div>
				</div>
			</div>
		{%- endif -%}
		
        {%- if is_entirely_fulfilled and has_one_fulfillment -%}
			{%- assign fulfillment = '' -%}

			{%- for line_item in order.line_items -%}
				{%- if line_item.fulfillment -%}
					{%- assign fulfillment = line_item.fulfillment -%}
					{%- break -%}
				{%- endif -%}
			{%- endfor -%}
			
			<div class="Grid__Cell 1/3--lap-and-up">
				<div class="Segment Segment--boxed">
					<h2 class="Segment__Title Heading u-h3">
    	  			  {%- assign titleArray = 'customer.order.tracking_numbers' | t | split: ' ' -%}
    	  			  <span>
    	  				  {%- for word in titleArray -%}
    	  				  	{%- if forloop.last -%}
    	  						<em>{{ word }}</em>
    	  					{%- else -%}	
    	  						{{ word | append: ' ' }}
    	  					{%- endif -%}
    	  				  {%- endfor -%}
    	  			  </span>
					</h2>
		            <div class="Segment__Content">
						<p class="Heading Heading--caps Heading--textFont u-h6">{{ fulfillment.tracking_company }}</p>
						<a class="Link Link--underline Link--primary" href="{{ fulfillment.tracking_url }}">#{{ fulfillment.tracking_number }}</a>
		            </div>
				</div>
			</div>
        {%- endif -%}
		
		<div class="Grid__Cell">
			<div class="Segment Segment--boxed">
				<h2 class="Segment__Title Heading u-h3">
  	  			  {%- assign titleArray = 'customer.order.order_details_title' | t | split: ' ' -%}
  	  			  <span>
  	  				  {%- for word in titleArray -%}
  	  				  	{%- if forloop.last -%}
  	  						<em>{{ word }}</em>
  	  					{%- else -%}	
  	  						{{ word | append: ' ' }}
  	  					{%- endif -%}
  	  				  {%- endfor -%}
  	  			  </span>
				</h2>

				<div class="Segment__Content">
					{%- assign placed_at = order.created_at | date: format: 'date_at_time' -%}
					<p>{{ 'customer.order.placed_at' | t: date: placed_at }}</p>
					
			        {%- if order.cancelled -%}
			          {%- assign cancelled_at = order.cancelled_at | date: format: 'date_at_time' -%}
			          <p>{{ 'customer.order.cancelled_at' | t: date: cancelled_at }}</p>
			        {%- endif -%}
	  
					<div class="TableWrapper">
						<table class="AccountTable Table Table--noBorder">
							<thead class="Heading Heading--caps Heading--textFont u-h6">
								<tr>
									<th><strong>{{ 'customer.order.product' | t }}</strong></th>
									<th class="Text--alignCenter hidden-phone"><strong>{{ 'customer.order.quantity' | t }}</strong></th>
									<th class="Text--alignRight"><strong>{{ 'customer.order.line_price' | t }}</strong></th>
								</tr>
							</thead>

							<tbody>
								{%- for line_item in order.line_items -%}
									{%- liquid
										assign product_title = line_item.product.title
										if product_title contains '|'
											assign raw_product_title_parts = product_title | split: '|'
											assign raw_product_title_parts_first = raw_product_title_parts | first
											assign raw_product_title_parts_last = raw_product_title_parts | last
											assign product_title = raw_product_title_parts_first | append: '<span class="ProductMeta__SubTitle"> | <em>' | append: raw_product_title_parts_last | append: '</em></span>'
										endif 
									-%}
									<tr>
										<td>
											<div class="CartItem__Info">
												<h2 class="CartItem__Title">
													<a href="{{ line_item.url }}">{{ product_title }}</a>
												</h2>

												<div class="CartItem__Meta">
										            {%- unless line_item.product.has_only_default_variant -%}
										  				{%- if line_item.variant.option1 != blank and line_item.variant.option1 != 'Custom' -%}
										  					<p class="CartItem__Variant Text--highlight">
										  						{{ line_item.product.options[0] }}: {{ line_item.variant.option1 }}
										  					</p>
										  				{%- endif -%}
				
										  				{%- if line_item.variant.option2 != blank and line_item.variant.option2 != 'Custom' -%}
										  					<p class="CartItem__Variant Text--highlight">
										  						{{ line_item.product.options[1] }}: {{ line_item.variant.option2 }}
										  					</p>
										  				{%- endif -%}
				
										  				{%- if line_item.variant.option3 != blank and line_item.variant.option3 != 'Custom' -%}
										  					<p class="CartItem__Variant Text--highlight">
										  						{{ line_item.product.options[2] }}: {{ line_item.variant.option3 }}
										  					</p>
										  				{%- endif -%}
										            {%- endunless -%}

													{%- if line_item.selling_plan_allocation -%}
														<p class="CartItem__PlanAllocation">{{ line_item.selling_plan_allocation.selling_plan.name }}</p>
													{%- endif -%}

													{%- if line_item.properties != empty -%}
														<ul class="CartItem__PropertyList Text--highlight">
															{%- for property in line_item.properties -%}
																{%- assign first_character_in_key = property.first | truncate: 1, '' -%}

																{%- if property.last == blank or first_character_in_key == '_' -%}
																	{%- continue -%}
																{%- endif -%}

																<li class="CartItem__Property">{{ property.first }}: {{ property.last }}</li>
															{%- endfor -%}
														</ul>
													{%- endif -%}

													<div class="CartItem__PriceList">
														{%- if line_item.original_price != line_item.final_price -%}
															<span class="CartItem__Price Price Price--highlight">{{ line_item.final_price | money_with_currency | remove: '.00' }}</span>
															<span class="CartItem__OriginalPrice Price Price--compareAt">{{ line_item.original_price | money_with_currency | remove: '.00' }}</span>
														{%- else -%}
															<span class="CartItem__Price Price">{{ line_item.final_price | money_with_currency | remove: '.00' }}</span>
														{%- endif -%}

														{%- if line_item.line_level_discount_allocations != blank -%}
															<ul class="CartItem__DiscountList">
																{%- for discount_allocation in line_item.line_level_discount_allocations -%}
																	<li class="CartItem__Discount">
																		{%- render 'icon' with 'sale' -%}{{ discount_allocation.discount_application.title }}: -{{ discount_allocation.amount | money_with_currency | remove: '.00' }}
																	</li>
																{%- endfor -%}
															</ul>
														{%- endif -%}
													</div>

													{%- if line_item.unit_price_measurement -%}
														<div class="CartItem__UnitPriceMeasurement">
															<div class="UnitPriceMeasurement Heading">
																<span class="UnitPriceMeasurement__Price">{{ line_item.unit_price | money_with_currency | remove: '.00' }}</span>
																<span class="UnitPriceMeasurement__Separator">/ </span>

																{%- if line_item.unit_price_measurement.reference_value != 1 -%}
																	<span class="UnitPriceMeasurement__ReferenceValue">{{ line_item.unit_price_measurement.reference_value }}</span>
																{%- endif -%}

																<span class="UnitPriceMeasurement__ReferenceUnit">{{ line_item.unit_price_measurement.reference_unit }}</span>
															</div>
														</div>
													{%- endif -%}
												</div>
											</div>
										</td>

										<td class="Text--alignCenter hidden-phone">{{ line_item.quantity }}</td>

										<td class="Text--alignRight">
											{%- if line_item.original_line_price != line_item.final_line_price -%}
												<span class="CartItem__Price Price Price--highlight">{{ line_item.final_line_price | money_with_currency | remove: '.00' }}</span>
												<span class="CartItem__OriginalPrice Price Price--compareAt">{{ line_item.original_line_price | money_with_currency | remove: '.00' }}</span>
											{%- else -%}
												<span class="CartItem__Price Price">{{ line_item.final_line_price | money_with_currency | remove: '.00' }}</span>
											{%- endif -%}
										</td>
									</tr>

									{%- if line_item.fulfillment and has_one_fulfillment == false -%}
										<tr>
											<td colspan="3">
												<p class="Alert Alert--large Alert--success">{{ 'customer.order.line_fulfillment_html' | t: product_title: line_item.product.title, tracking_url: line_item.fulfillment.tracking_url, tracking_number: line_item.fulfillment.tracking_number }}</p>
											</td>
										</tr>
									{%- endif -%}
								{%- endfor -%}
							</tbody>

							<tfoot>
								<tr>
									<td class="hidden-phone"></td>
									<td class="hidden-phone"></td>
									<td class="Text--alignRight">{{ 'customer.order.subtotal' | t }}: {{ order.line_items_subtotal_price | money_with_currency | remove: '.00' }}</td>
								</tr>

								{%- for discount_application in order.cart_level_discount_applications -%}
									<tr>
										<td class="hidden-phone"></td>
										<td class="hidden-phone"></td>
										<td class="Text--alignRight">{{ 'customer.order.discount' | t }}({{ discount_application.title }}): -{{ discount_application.total_allocated_amount | money_with_currency | remove: '.00' }}</td>
									</tr>
								{%- endfor -%}

								{%- for shipping_method in order.shipping_methods -%}
									<tr>
										<td class="hidden-phone"></td>
										<td class="hidden-phone"></td>
										<td class="Text--alignRight">{{ 'customer.order.shipping' | t }}({{ shipping_method.title }}): {{ shipping_method.price | money_with_currency | remove: '.00' }}</td>
									</tr>
								{%- endfor -%}

								{%- for tax_line in order.tax_lines -%}
									<tr>
										<td class="hidden-phone"></td>
										<td class="hidden-phone"></td>
										<td class="Text--alignRight">{{ 'customer.order.tax' | t }} ({{ tax_line.title }} {{ tax_line.rate_percentage }}%): {{ tax_line.price | money_with_currency | remove: '.00' }}</td>
									</tr>
								{%- endfor -%}

								<tr>
									<td class="hidden-phone"></td>
									<td class="hidden-phone"></td>
									<td class="Heading Text--alignRight Heading--caps Heading--textFont u-h6"><span><strong>{{ 'customer.order.total' | t }} {{ order.total_price | money_with_currency | remove: '.00' }}</strong></span></td>
								</tr>
							</tfoot>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
  "name": "Customer order"
}
{% endschema %}