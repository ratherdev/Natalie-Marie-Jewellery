<style>
.masonry-gallery {
  padding: 40px 20px;
}

.gallery-grid {
  column-count: {{ section.settings.columns_desktop }};
  column-gap: {{ section.settings.gap }}px;
}

.gallery-item {
  break-inside: avoid;
  margin-bottom: {{ section.settings.gap }}px;
  border-radius: {{ section.settings.radius }}px;
  overflow: hidden;
  background: #fff;
  position: relative;
  display: none; /* important for pagination */
}

.gallery-item img {
  width: 100%;
  display: block;
  border-radius: {{ section.settings.radius }}px;
}

/* ratios */
.ratio-natural img { height: auto; }

.ratio-square { aspect-ratio: 1/1; }
.ratio-square img { width:100%; height:100%; object-fit:cover; }

.ratio-rectangle { aspect-ratio: 4/5; }
.ratio-rectangle img { width:100%; height:100%; object-fit:cover; }

/* text */
.masonry-gallery-advance h2 {
  font-family: "BaskervilleDisplayPT";
  font-size: 50px;
  text-align: center;
}

.masonry-gallery-advance > p {
  font-size: 16px;
  max-width: 600px;
  margin: auto;
  text-align: center;
  padding: 8px 0 50px;
}

.gallery-item h4 {
  font-size: 18px;
  text-transform: uppercase;
  text-align: center;
  margin-top: 10px;
  font-weight: bold;
}

.gallery-item p {
  text-align: center;
  font-size: 14px;
  margin-bottom: 10px;
}

/* pagination button */
.load-more-wrapper {
  text-align: center;
  margin-top: 30px;
}

/* mobile */
@media (max-width: 768px) {
  .gallery-grid {
    column-count: {{ section.settings.columns_mobile }};
  }

  .masonry-gallery-advance h2 {
    font-size: 32px;
  }
}
</style>
<section class="masonry-gallery masonry-gallery-advance">
  
  {% if section.settings.title != blank %}
    <h2>{{ section.settings.title }}</h2>
  {% endif %}

  {% if section.settings.description != blank %}
    <p>{{ section.settings.description }}</p>
  {% endif %}

  <div class="gallery-grid" id="galleryGrid">
    {% for block in section.blocks %}
      <div class="gallery-item ratio-{{ block.settings.image_ratio }} gallery-page-item">
        
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}">
        {% endif %}

        {% if block.settings.image %}
          <img src="{{ block.settings.image | img_url: '800x' }}" alt="">
        {% endif %}

        {% if block.settings.title != blank %}
          <h4>{{ block.settings.title }}</h4>
        {% endif %}

        {% if block.settings.desc != blank %}
          <p>{{ block.settings.desc }}</p>
        {% endif %}

        {% if block.settings.link != blank %}
          </a>
        {% endif %}

      </div>
    {% endfor %}
  </div>

  <!-- Load More -->
  <div class="load-more-wrapper">
    <button id="loadMoreBtn" class="button button--primary">
      {{ section.settings.button_text }}
    </button>
  </div>

</section>
<script>
document.addEventListener("DOMContentLoaded", function () {

  const items = document.querySelectorAll(".gallery-page-item");
  const btn = document.getElementById("loadMoreBtn");

  const perPage = {{ section.settings.items_per_page }};
  let currentItems = perPage;

  function showItems() {
    items.forEach((item, index) => {
      if (index < currentItems) {
        item.style.display = "block";
      } else {
        item.style.display = "none";
      }
    });

    if (currentItems >= items.length) {
      btn.style.display = "none";
    }
  }

  showItems();

  btn.addEventListener("click", function () {
    currentItems += perPage;
    showItems();

    // smooth scroll
    window.scrollTo({
      top: items[currentItems - perPage].offsetTop - 100,
      behavior: "smooth"
    });
  });

});
</script>
{% schema %}
{
  "name": "Masonry Gallery Advanced",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "items_per_page",
      "label": "Images per page",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 25
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Load More Button Text",
      "default": "Load More"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Border Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 12
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Image Title"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Image Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Image Shape",
          "default": "natural",
          "options": [
            { "value": "square", "label": "Square" },
            { "value": "rectangle", "label": "Rectangle" },
            { "value": "natural", "label": "Full (Original)" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery Advanced"
    }
  ]
}
{% endschema %}