{%- for block in section.blocks -%}
	{%- capture media_content -%}
		{%- if block.settings.video != blank -%}
			{%- assign media = block.settings.video -%}
			<div class="StyledWith__VideoContainer AspectRatio AspectRatio--withFallback" style="padding-bottom: {{ 100.0 | divided_by: media.aspect_ratio }}%; --aspect-ratio: {{ media.aspect_ratio }}; background-image: url({{ media.preview_image | img_url: '1x1', format: 'jpg' }});">
				{%- if block.settings.style_tag != blank -%}
					<h3 class="StyleLink Heading Heading--caps Heading--textFont Text--highlight ColourStyle--{{ section.settings.colour_style }}"><span>{% if block.settings.link != blank %}<a href="{{ block.settings.link }}" target="_blank">{% endif %}<strong>{{ block.settings.style_tag }}</strong>{% if block.settings.link != blank %}</a>{% endif %}</span></h3>
				{%- endif -%}
				<video controlsList="nodownload" class="StyledWith__Video lazyVideo" playsinline="playsinline" {% if block.settings.autoplay %}autoplay="autoplay"{% endif %} {% if block.settings.loop %}loop="loop"{% endif %} muted="muted" preload="metadata" poster="{{ media.preview_image | img_url: '1200x' }}">
					{% for source in media.sources %}
						{% if source.mime_type == 'application/x-mpegURL'%}{% continue %}{% endif %}
						<source data-src="{{ source.url }}" type="{{ source.mime_type }}">
					{% endfor %}
					<img src="{{ media.preview_image | img_url: '1200x' }}">
				</video>
			</div>
		{%- elsif block.settings.image != blank -%}
			<div class="StyledWith__ImageContainer AspectRatio AspectRatio--withFallback" style="padding-bottom: {{ 100.0 | divided_by: block.settings.image.aspect_ratio }}%; --aspect-ratio: {{ block.settings.image.aspect_ratio }}; background-image: url({{ block.settings.image | img_url: '1x1', format: 'jpg' }})">
				{%- if block.settings.style_tag != blank -%}
					<h3 class="StyleLink Heading Heading--caps Heading--textFont Text--highlight ColourStyle--{{ section.settings.colour_style }}"><span>{% if block.settings.link != blank %}<a href="{{ block.settings.link }}" target="_blank">{% endif %}<strong>{{ block.settings.style_tag }}</strong>{% if block.settings.link != blank %}</a>{% endif %}</span></h3>
				{%- endif -%}
				
				{% assign image_url = block.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}

				<img class="StyledWith__Image Image--lazyLoad hide-no-js"
					data-src="{{ image_url }}"
					data-optimumx="1.2"
					data-widths="[400, 600, 800, 1000, 1200, 1400, 1600, 1800, 2000, 2200]"
					data-sizes="auto"
					alt="{{ block.settings.image.alt | escape }}">

				<noscript>
					<img class="StyledWith__Image" src="{{ block.settings.image | img_url: '1000x' }}" alt="{{ block.settings.image.alt | escape }}">
				</noscript>
			</div>
		{%- endif -%}
		
		{%- if block.settings.description != blank -%}
			<p class="ColourStyle--{{ section.settings.colour_style }}"><span>{{ block.settings.description }}</span></p>
		{%- endif -%}
		{%- if block.settings.products != blank -%}
			{%- if block.settings.title != blank -%}
				<h3 class="Heading u-h6 ColourStyle--{{ section.settings.colour_style }}"><span>{{ block.settings.title }}</span></h3>
			{%- endif -%}
			<h3 class="Heading u-h6 ColourStyle--{{ section.settings.colour_style }}">
				<span>
					<ol>
						{%- for product in block.settings.products -%}
							{%- if product.available -%}
								{%- liquid
									assign product_title = product.title
									if product_title contains '|'
										assign raw_product_title_parts = product_title | split: '|'
										assign raw_product_title_parts_first = raw_product_title_parts | first
										assign raw_product_title_parts_last = raw_product_title_parts | last
										assign product_title = raw_product_title_parts_first | append: '<span class="ProductMeta__SubTitle"> | <em>' | append: raw_product_title_parts_last | append: '</em></span>'
									endif 
								-%}
								<li><a href="{{ product.url }}">{{ product_title }}</a></li>
							{%- endif -%}
						{%- endfor -%}
					</ol>
				</span>
			</h3>
		{%- endif -%}
		
	{%- endcapture -%}
	
	{%- if media_content != blank and forloop.index == 1 -%}
		{%- capture media_content_1 -%}{{ media_content }}{%- endcapture -%}
	{%- elsif media_content != blank and forloop.index == 2 -%}
		{%- capture media_content_2 -%}{{ media_content }}{%- endcapture -%}
	{%- elsif media_content != blank and forloop.index == 3 -%}
		{%- capture media_content_3 -%}{{ media_content }}{%- endcapture -%}
	{%- endif -%}
	
{%- endfor -%}

{%- capture section_content -%}
	{%- capture text_content -%}
		{%- if section.settings.subheading != blank -%}
			<h3 class="SectionHeader__SubHeading Heading Heading--caps Heading--textFont u-h6"><span>{{ section.settings.subheading }}</span></h3>
		{%- endif -%}

		{%- if section.settings.title != blank -%}
			<h2 class="SectionHeader__Heading Heading u-h3"><span>{{ section.settings.title }}</span></h2>
		{%- endif -%}
	
		{%- if section.settings.description != blank -%}
			<div class="SectionHeader__Description SectionHeader__Description--primary Rte">
				{{ section.settings.description }}
			</div>
		{%- endif -%}

		{%- if section.settings.button_1_text != blank and section.settings.button_2_text != blank -%}
			{%- assign has_two_buttons = true -%}
		{%- else -%}
			{%- assign has_two_buttons = false -%}
		{%- endif -%}

		{%- if section.settings.button_1_text != blank or section.settings.button_2_text != blank -%}
			<div class="SectionHeader__ButtonWrapper">
				<div class="ButtonGroup ButtonGroup--spacingSmall {% if has_two_buttons %}ButtonGroup--sameSize{% endif %}">
					{%- if section.settings.button_1_text != blank -%}
						<a href="{{ section.settings.button_1_link }}" class="ButtonGroup__Item {% if section.settings.button_style == 'underline' %}Link Link--underline{% else %}Button Button--{{ section.settings.button_style }}{% endif %}">{{ section.settings.button_1_text | escape }}</a>
					{%- endif -%}

					{%- if block.settings.button_2_text != blank -%}
						<a href="{{ section.settings.button_2_link }}" class="ButtonGroup__Item {% if section.settings.button_style == 'underline' %}Link Link--underline{% else %}Button Button--{{ section.settings.button_style }}{% endif %}">{{ section.settings.button_2_text | escape }}</a>
					{%- endif -%}
				</div>
			</div>
		{%- endif -%}
	{%- endcapture -%}

	{%- if text_content != blank -%}
		<div class="StyledWith__ContentWrapper">
			<div class="StyledWith__Content ColourStyle--{{ section.settings.colour_style }}">
				<header class="SectionHeader SectionHeader--center">
					{{ text_content }}
				</header>
			</div>
		</div>
	{%- endif -%}
{%- endcapture -%}

{%- if media_content_1 != blank -%}
	{{ 'section-styled-with.css' | asset_url | stylesheet_tag }}
	<section class="Section Section--spacingExtraLarge {% if section.settings.separate_section_with_border %}bordered-section{% endif %}" id="section-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="styled-with" {% if section.settings.enable_dark %}data-section-theme='dark'{% endif %}>
		<div class="Container">
			<div class="StyledWith Grid">
				<div class="Grid__Cell hidden-pocket 2/16--lap-and-up"></div>
				<div class="Grid__Cell Border 12/16--lap-and-up">
					
					{%- if section_content != blank -%}
						{{ section_content }}
					{%- endif -%}
					
					<div class="Grid">
						{%- if media_content_3 != blank -%}
							<div class="Grid__Cell 1/16--pocket hidden-lap-and-up"></div>
							<div class="Grid__Cell StyledWith--content_1 11/16--pocket 5/16--lap-and-up">
								{{ media_content_1 }}
							</div>
							<div class="Grid__Cell 4/16--pocket hidden-lap-and-up"></div>
							
					
							<div class="Grid__Cell 4/16--pocket 1/16--lap-and-up"></div>
							<div class="Grid__Cell StyledWith--content_2 11/16--pocket 4/16--lap-and-up">
								{{ media_content_2 }}
							</div>
							<div class="Grid__Cell 1/16--pocket 1/16--lap-and-up"></div>
							
							
							<div class="Grid__Cell 1/16--pocket hidden-lap-and-up"></div>
							<div class="Grid__Cell StyledWith--content_3 11/16--pocket 5/16--lap-and-up">
								{{ media_content_3 }}
							</div>
							<div class="Grid__Cell 4/16--pocket hidden-lap-and-up"></div>
						{%- elsif media_content_2 != blank -%}
							<div class="Grid__Cell 1/16--pocket hidden-lap-and-up"></div>
							<div class="Grid__Cell StyledWith--content_1 11/16--pocket 5/16--lap-and-up">
								{{ media_content_1 }}
							</div>
							<div class="Grid__Cell 4/16--pocket hidden-lap-and-up"></div>
							
					
							<div class="Grid__Cell 4/16--pocket 1/16--lap-and-up"></div>
							<div class="Grid__Cell StyledWith--content_2 11/16--pocket 4/16--lap-and-up">
								{{ media_content_2 }}
							</div>
							<div class="Grid__Cell 1/16--pocket 1/16--lap-and-up"></div>
						{%- else -%}
							<div class="Grid__Cell 1/16--pocket hidden-lap-and-up"></div>
							<div class="Grid__Cell StyledWith--content_1 11/16--pocket 5/16--lap-and-up">
								{{ media_content_1 }}
							</div>
							<div class="Grid__Cell 4/16--pocket hidden-lap-and-up"></div>
						{%- endif -%}
					</div>
					
				</div>
				<div class="Grid__Cell 2/16--lap-and-up"></div>
			</div>
		</div>
	</section>
		
{%- endif -%}

{% schema %}
{
  "name": "Styled with",
  "max_blocks": 3,
  "settings": [
      {
        "type": "checkbox",
        "id": "separate_section_with_border",
        "label": "Separate section with border",
        "default": true
      },
	  {
        "type": "checkbox",
        "id": "enable_dark",
        "label": "Enable dark background",
        "default": false
      },
	  {
	    "type": "header",
	    "content": "Text"
	  },
	  {
	    "type": "image_picker",
	    "id": "logo_image",
	    "label": "Title image",
	    "info": "1800 x 800px .jpg recommended"
	  },
	  {
	    "type": "richtext",
	    "id": "subheading",
	    "label": "Sub-heading"
	  },
	  {
	    "type": "richtext",
	    "id": "title",
	    "label": "Heading",
	    "default": "<p>Styled <em>By</em></p>"
	  },
	  {
	    "type": "richtext",
	    "id": "description",
	    "label": "Description"
	  },
	  {
	    "type": "richtext",
	    "id": "feature_text",
	    "label": "Feature heading"
	  },
	  {
	    "type": "header",
	    "content": "Text Settings"
	  },
	  {
	    "type": "select",
	    "id": "colour_style",
	    "label": "Colour style",
	    "options": [
	      {
	        "value": "light",
	        "label": "Light"
	      },
	      {
	        "value": "dark",
	        "label": "Dark"
	      }
	    ],
	    "default": "dark",
		"info": "Sets the text and button colour."
	  },
	  {
	    "type": "header",
	    "content": "Button 1"
	  },
	  {
	    "type": "text",
	    "id": "button_1_text",
	    "label": "Text"
	  },
	  {
	    "type": "url",
	    "id": "button_1_link",
	    "label": "Link"
	  },
	  {
	    "type": "header",
	    "content": "Button 2"
	  },
	  {
	    "type": "text",
	    "id": "button_2_text",
	    "label": "Text"
	  },
	  {
	    "type": "url",
	    "id": "button_2_link",
	    "label": "Link"
	  },
	  {
	    "type": "header",
	    "content": "Button Settings"
	  },
	  {
	    "type": "select",
	    "id": "button_style",
	    "label": "Button style",
	    "options": [
	      {
	        "value": "underline",
	        "label": "Text underline"
	      },
	      {
	        "value": "secondary",
	        "label": "Secondary Button"
	      },
	      {
	        "value": "primary",
	        "label": "Primary Button"
	      }
	    ],
	    "default": "underline",
	    "info": "Sets the style for the button."
	  }
  ],
  "blocks": [
    {
      "type": "style",
      "name": "Style",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "1800 x 800px .jpg recommended"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay video",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "loop",
          "label": "Loop video",
          "default": true
        },
        {
		  "type": "text",
		  "id": "style_tag",
		  "label": "Style tag"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Style link"
        },
        {
		  "type": "header",
		  "content": "Styled with"
        },
        {
		  "type": "richtext",
		  "id": "description",
		  "label": "Description"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
          "default": "<p>Styled <em>with:</em></p>",
		  "info": "Only displayed if product references are set."
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Products",
          "info": "Add references to products shown."
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Content",
      "name": "Styled with",
      "settings": {},
      "blocks": [
        {
          "type": "style"
        }
      ]
    }
  ]
}
{% endschema %}