{% comment %}
------------------------------------------------------------------------------
Product Data. This must be outputted for all products (including home page).

IMPORTANT: THIS CODE IS VITAL. DO NOT EDIT IT NOT REMOVE IT. MAKE SURE TO KEEP
THE EXACT SAME ATTRIBUTES.
------------------------------------------------------------------------------
{% endcomment %}

{%- assign inventory_block = section.blocks | where: 'type', 'inventory' | first -%}

<script type="application/json" data-product-json>
	{
		"product": {{ product | json }},
		"selected_variant_id": {{ product.selected_or_first_available_variant.id }}
		{%- if inventory_block != blank -%}
			,"inventories": {
				{%- for variant in product.variants -%}
					{%- assign inventory_message = '' -%}
					{%- capture inventory_message -%}
						{%- if variant.inventory_quantity > inventory_block.settings.inventory_quantity_threshold or variant.inventory_management != 'shopify' -%}
							{%- render 'icon', icon: 'checkmark' -%} <span class="DispatchTime">Ready for immediate dispatch</span>
							{%- assign inventory_dispatch = '' -%}
						{%- else -%}
							{%- render 'icon', icon: 'information' -%} Crafted for you | Estimated dispatch <span class="DispatchTime">{{ product.metafields.custom.dispatch }}</span>
							{%- assign inventory_dispatch = product.metafields.custom.dispatch -%}
						{%- endif -%}
					{%- endcapture -%}
					
					{%- capture inventory_message_made_to_order -%}
						{%- render 'icon', icon: 'information' -%} Crafted for you | Estimated dispatch <span class="DispatchTime">{{ product.metafields.custom.personalisation_dispatch }}</span>
					{%- endcapture -%}
					
					"{{ variant.id }}": {
						"inventory_management": {{ variant.inventory_management | json }},
						"inventory_policy": {{ variant.inventory_policy | json }},
						"inventory_quantity": {{ variant.inventory_quantity | json }},
						"inventory_message": {{ inventory_message | json }},
						"inventory_message_made_to_order": {{ inventory_message_made_to_order | json }},
						"inventory_dispatch": {{ inventory_dispatch | json }},
						"inventory_personalisation_dispatch": {{ product.metafields.custom.personalisation_dispatch | json }}
					}{% unless forloop.last %},{% endunless %}
				{%- endfor -%}
			}
		{%- else -%}	
			,"inventories": {
				{%- for variant in product.variants -%}
					{%- assign inventory_message = '' -%}
					
					{%- if variant.inventory_quantity > 0 or variant.inventory_management != 'shopify' -%}
						{%- assign inventory_dispatch = '' -%}
					{%- else -%}
						{%- assign inventory_dispatch = product.metafields.custom.dispatch -%}
					{%- endif -%}

				
					"{{ variant.id }}": {
						"inventory_management": {{ variant.inventory_management | json }},
						"inventory_policy": {{ variant.inventory_policy | json }},
						"inventory_quantity": {{ variant.inventory_quantity | json }},
						"inventory_message": {{ inventory_message | json }},
						"inventory_dispatch": {{ inventory_dispatch | json }},
						"inventory_personalisation_dispatch": {{ product.metafields.custom.personalisation_dispatch | json }}
					}{% unless forloop.last %},{% endunless %}
				{%- endfor -%}
			}
		{%- endif -%}
  }
</script>