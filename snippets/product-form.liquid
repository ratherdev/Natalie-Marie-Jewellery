{%- comment -%}
Those are the option names for which we automatically detect swatch. For the color, we use them to display a swatch, while
for size, we use it to display a size chart (if applicable)
{%- endcomment -%}

{%- assign color_label = 'metal,color,colour,couleur,colore,farbe,색,色,färg,farve' | split: ',' -%}
{%- assign size_label = 'size,taille,größe,tamanho,tamaño,koko,サイズ' | split: ',' -%}
{%- assign custom_size_label = 'ring size' | split: ',' -%}

{%- assign product_popovers = '' -%}
{%- assign show_option_label = false -%}

{%- assign selected_variant = product.selected_or_first_available_variant -%}

{%- assign additionalDrawersHtml = '' -%} 

<div class="ProductForm__Variants">
	{%- unless product.has_only_default_variant -%}
		{%- assign show_metal_meta = true -%}
		{%- assign show_width_meta = true -%}
		
		{%- for option in product.options_with_values -%}
			{%- assign downcase_option = option.name | downcase -%}
			{%- if downcase_option == 'metal' -%}
				{%- assign show_metal_meta = false -%}
			{%- endif -%}
			{%- if downcase_option == 'width' -%}
				{%- assign show_width_meta = false -%}
			{%- endif -%}

			{%- if block.settings.selector_mode == 'block' or color_label contains downcase_option and block.settings.show_color_swatch -%}
				{%- assign show_option_label = true -%}
			{%- endif -%}
		{%- endfor -%}
		
		{%- if show_metal_meta and product.metafields.custom.metal.value != blank -%}
			<input type="hidden" name="properties[Metal]" value="{{ product.metafields.custom.metal.value.title }}" data-active="true">
		{%- endif -%}
		
		{%- if show_width_meta and product.metafields.custom.width.value != blank -%}
			<input type="hidden" name="properties[Width]" value="{{ product.metafields.custom.width.value.title }}" data-active="true">
		{%- endif -%}

		{%- for option in product.options_with_values -%}
			{%- assign downcase_option = option.name | downcase -%}
			{%- capture popover_id -%}popover-{{ product.id }}-{{ section.id }}-{{ option.name | handle }}{%- endcapture -%}
			
			<div class="ProductForm__Option {% if show_option_label %}ProductForm__Option--labelled{% endif %} {% if option.values.size == 1 %}{% unless custom_size_label contains downcase_option %}hidden-pocket hidden-lap-and-up{% endunless %}{% endif %}" style="{% if downcase_option contains 'carat' %}order: 1{% endif %}">
				
				{%- if custom_size_label contains downcase_option -%}
					{%- assign optionGuide = option.name | append: '-guide' | handle -%}
					{%- assign metaobject = product.metafields.custom.size_guide.value -%}
				{%- else -%}
					{%- assign optionGuide = option.name | append: '-guide' | handle -%}
					{%- assign metaobject = shop.metaobjects['guide'][optionGuide] -%}
				{%- endif -%}
				
				{%- assign drawerID = optionGuide -%}
				{%- assign guideButton = '' -%}
				
				{%- if metaobject != blank -%}
					{%- capture additionalDrawerHtml -%}
					  	{%- render 'additional-drawer', 
							drawerID: drawerID, 
							drawerTitle: '', 
							drawerContent: '', 
							drawerFooterContent: '',
							metaobject: metaobject,
							option: option
						-%}
					{%- endcapture -%}

					{%- assign additionalDrawersHtml = additionalDrawersHtml | append: additionalDrawerHtml -%}
					
					{%- capture guideButton -%}
						{%- if additionalDrawerHtml != blank -%}
							<div class="Link Link--tertiary Link--underline" data-action="open-drawer" data-drawer-id="{{ drawerID }}" aria-label="{{ metaobject.link_title }}">{{ metaobject.link_title }}</div>
						{%- endif -%}		
					{%- endcapture -%}
				{%- endif -%}
				
				{%- if show_option_label -%}
					<div class="Grid">
						<div class="Grid__Cell 2/3--lap-and-up">
							<div class="ProductForm__LabelWrapper">
								<span class="ProductForm__Label">
									{{ option.name }}:

									{% if color_label contains downcase_option and block.settings.show_color_swatch %}
										<span class="ProductForm__SelectedValue">{{ option.selected_value }}</span>
									{% endif %}
								</span>
					
								{%- if guideButton != blank -%}
									<div>
										{{ guideButton }}
									</div>
								{%- endif -%}
							</div>
						</div>
					</div>
				{%- endif -%}
				
				{%- if custom_size_label contains downcase_option -%}
					<div class="Grid">
						<div class="Grid__Cell 2/3--lap-and-up">
							<button type="button" class="ProductForm__Item" aria-expanded="false" data-action="open-drawer" data-drawer-id="{{ drawerID }}">
								<span class="ProductForm__OptionName">{% unless show_option_label %}{{ option.name }}: {% endunless %}<span class="ProductForm__SelectedValue">Select ring size</span></span>
								{%- render 'icon' with 'select-arrow-right' -%}
							</button>
						</div>
						
						<input id="ring_size" class="Form__Input" data-custom-label="Ring Size" type="hidden" name="properties[Ring Size]" required>
					</div>
				
				{%- elsif color_label contains downcase_option and block.settings.show_color_swatch -%}
				{% if color_label contains 'metal'  %}
					<div class="Grid__Cell 2/3--lap-and-up" style="padding-left: 0;">
					<div class="Grid">
{%- assign color_swatch_config = settings.color_swatch_config | newline_to_br | split: '<br />' -%}

						{%- for value in option.values -%}
							{%- assign downcase_value = value | downcase -%}
							<div class="Grid__Cell Grid__Cell--expand 1/4">
								<input id="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="SizeSwatch__Radio" type="radio" name="option-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" {% if value == option.selected_value %}checked="checked"{% endif %} data-option-position="{{ option.position }}">
								<label for="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="SizeSwatch SizeSwatch--expand {% if downcase_value == 'white' %}ColorSwatch--white{% endif %}" data-tooltip="{{ value | escape }}" style="{% render 'color-swatch-style', color_swatch_config: color_swatch_config, value: value %}">
									<span>{{ value }}</span>
								</label>
							</div>
						
						{%- endfor -%}
					</div>	</div>			
							{% else %}
					<ul class="ColorSwatchList HorizontalList HorizontalList--spacingTight">
						{%- assign color_swatch_config = settings.color_swatch_config | newline_to_br | split: '<br />' -%}

						{%- for value in option.values -%}
							{%- assign downcase_value = value | downcase -%}<li class="HorizontalList__Item">
								<input id="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="ColorSwatch__Radio" type="radio" name="option-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" {% if value == option.selected_value %}checked="checked"{% endif %} data-option-position="{{ option.position }}">
								<label for="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="ColorSwatch ColorSwatch--large {% if downcase_value == 'white' %}ColorSwatch--white{% endif %}" data-tooltip="{{ value | escape }}" style="{% render 'color-swatch-style', color_swatch_config: color_swatch_config, value: value %}">
									<span class="u-visually-hidden">{{ value }}</span>
								</label>
							</li>
						
						{%- endfor -%}
					</ul>
					{% endif %}
				{%- elsif block.settings.selector_mode == 'block' -%}
					<div class="Grid">
						<div class="Grid__Cell 2/3--lap-and-up">
							<div class="Grid">
								{%- for value in option.values -%}
									<div class="Grid__Cell {% unless option.values.size > 4 %}Grid__Cell--expand{% endunless %} 1/4">
										<input id="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="SizeSwatch__Radio" type="radio" name="option-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" {% if value == option.selected_value %}checked="checked"{% endif %} data-option-position="{{ option.position }}">
										<label for="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="SizeSwatch SizeSwatch--expand">{{ value }}</label>
									</div>
								{%- endfor -%}
							</div>
						</div>
					</div>
				{%- else -%}
					<div class="Grid">
						<div class="Grid__Cell 2/3--lap-and-up">
							<button type="button" class="ProductForm__Item" aria-expanded="false" aria-controls="{{ popover_id }}">
								<span class="ProductForm__OptionName">{% unless show_option_label %}{{ option.name }}: {% endunless %}<span class="ProductForm__SelectedValue">{{ option.selected_value }}</span></span>
								{%- render 'icon' with 'select-arrow' -%}
							</button>
						</div>
					</div>
						
					{%- capture popover_html -%}
						{%- if color_label contains downcase_option and block.settings.show_color_carousel -%}
							{%- for value in option.values -%}
								{%- if value == option.selected_value -%}
									{%- assign initial_image_index = forloop.index0 -%}
									{%- break -%}
								{%- endif -%}
							{%- endfor -%}

							{%- capture flickity_options -%}
							{
								"prevNextButtons": true,
								"pageDots": true,
								"initialIndex": {{ initial_image_index }},
								"arrowShape": {"x0": 20, "x1": 60, "y1": 40, "x2": 60, "y2": 35, "x3": 25}
							}
							{%- endcapture -%}

							<div id="{{ popover_id }}" class="VariantSelector" aria-hidden="true">
								{%- capture option_index -%}option{{ option.position }}{%- endcapture -%}

								{%- assign option_indexes_excluded_color = '' -%}
								{%- assign selected_variant_title_excluded_color = '' -%}

								{%- for option_nested in product.options_with_values -%}
									{%- if option_nested.position != option.position -%}
										{%- assign option_indexes_excluded_color = option_indexes_excluded_color | append: option_nested.position | append: ',' -%}

										{%- for option_nested_value in option_nested.values -%}
											{%- if option_nested_value == option_nested.selected_value -%}
												{%- assign selected_variant_title_excluded_color = selected_variant_title_excluded_color | append: option_nested_value -%}
											{%- endif -%}
										{%- endfor -%}
									{%- endif -%}
								{%- endfor -%}

								{%- assign option_indexes_excluded_color = option_indexes_excluded_color | split: ',' | compact -%}

								<div class="VariantSelector__Carousel Carousel" data-flickity-config='{{ flickity_options }}'>
									{%- for value in option.values -%}
										<div class="VariantSelector__Item Carousel__Cell {% if value == option.selected_value %}is-selected{% endif %}"
											data-background-color="{{ value | split: ' ' | last | handle }}"
											data-background-image="{{ value | handle | append: '.png' | asset_url }}"
											data-option-position="{{ option.position }}"
											data-option-value="{{ value | escape }}">
										
											{%- for variant in product.variants -%}
												{%- if variant[option_index] == value -%}
													{%- assign variant_image = variant.image | default: product.featured_image -%}

													{%- assign variant_title_excluded_color = '' -%}
													{%- for option_index_excluded_color in option_indexes_excluded_color -%}
														{%- capture sub_option_index -%}option{{ option_index_excluded_color }}{%- endcapture -%}
														{%- assign variant_title_excluded_color = variant_title_excluded_color | append: variant[sub_option_index] -%}
													{%- endfor -%}

													<div data-variant-title="{{ variant_title_excluded_color | escape }}" class="VariantSelector__ImageWrapper AspectRatio AspectRatio--withFallback" aria-hidden="{% if selected_variant_title_excluded_color == variant_title_excluded_color %}false{% else %}true{% endif %}" style="max-width: {{ variant_image.width }}px; padding-bottom: {{ 100.0 | divided_by: variant_image.aspect_ratio }}%; --aspect-ratio: {{ variant_image.aspect_ratio }}">
														{%- capture supported_sizes -%}{%- render 'image-size', sizes: '200,400,600,800', image: variant_image -%}{%- endcapture -%}
														{%- assign image_url = variant_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}

														<img class="VariantSelector__Image Image--lazyLoad Image--fadeIn" data-src="{{ image_url }}" data-widths="[{{ supported_sizes }}]" data-sizes="auto" alt="{{ variant_image.alt | escape }}">
														<span class="Image__Loader"></span>
													</div>
												{%- endif -%}
											{%- endfor -%}
										</div>
									{%- endfor -%}
								</div>

								<div class="VariantSelector__Info">
									<div class="VariantSelector__ChoiceList">
										{%- for value in option.values -%}
											{%- assign min_price_for_variant = product.price_max -%}

											{%- for variant in product.variants -%}
												{%- if variant[option_index] == value -%}
													{%- assign min_price_for_variant = min_price_for_variant | at_most: variant.price -%}
												{%- endif -%}
											{%- endfor -%}

											<div class="VariantSelector__Choice {% if value == option.selected_value %}is-selected{% endif %}">
												<div class="VariantSelector__ChoiceColor">
													{%- assign downcase_value = value | downcase -%}

													{%- assign color_swatch_name = value | handle | append: '.png' -%}
													{%- assign color_swatch_image = images[color_swatch_name] -%}

													<span class="VariantSelector__ColorSwatch {% if downcase_value == 'white' %}VariantSelector__ColorSwatch--white{% endif %}" style="background-color: {{ value | replace: ' ', '' | downcase }}; {% if color_swatch_image != blank %}background-image: url({{ color_swatch_image | img_url: '64x64' }}){% endif %}"></span>
													<span class="VariantSelector__ChoiceValue">{{ value }}</span>
												</div>

												<div class="VariantSelector__ChoicePrice" data-color-position="{{ option.position }}">
													{%- if available_prices_for_option_value.size > 1 -%}
														{%- capture formatted_min_price -%}<span>{{ min_price_for_variant | money }}</span>{%- endcapture -%}
														<span class="Heading Text--subdued">{{ 'product.form.from_price_html' | t: min_price: formatted_min_price }}</span>
													{%- else -%}
														<span class="Heading Text--subdued">{{ min_price_for_variant | money }}</span>
													{%- endif -%}
												</div>
											</div>
										{%- endfor -%}
									</div>

									<button type="button" class="VariantSelector__Button Button Button--primary Button--full" data-action="select-variant">{{- 'product.form.select_model' | t -}}</button>
								</div>
							</div>
						{%- else -%}
							<div id="{{ popover_id }}" class="OptionSelector Popover Popover--withMinWidth" aria-hidden="true">
								<header class="Popover__Header">
									<button type="button" class="Popover__Close Icon-Wrapper--clickable" data-action="close-popover">{% render 'icon' with 'close' %}</button>
									<span class="Popover__Title Heading u-h4">{{ option.name | escape }}</span>
								</header>

								<div class="Popover__Content">
									<div class="Popover__ValueList" data-scrollable>
										{%- for value in option.values -%}
											<button type="button" class="Popover__Value {% if value == option.selected_value %}is-selected{% endif %} Heading Link Link--primary u-h6"
												data-value="{{ value | escape }}"
												data-option-position="{{ option.position }}"
												data-action="select-value">
												{{- value | escape -}}
											</button>
										{%- endfor -%}
									</div>
								</div>
							</div>
						{%- endif -%}
					{%- endcapture -%}

					{%- assign product_popovers = product_popovers | append: popover_html -%}
				{%- endif -%}
			</div>
		{%- endfor -%}
	
		{%- if block.settings.stitch_stones or block.settings.stitch_metals -%}
			{%- render 'product-stitching', stitch_width: true, stitch_stones: block.settings.stitch_stones, stitch_metals: block.settings.stitch_metals, product: product, mode: 'swatch' -%}
		{%- endif -%}
		
		{%- if block.settings.enable_custom_line_properties and product.metafields.custom.custom_line_item_properties.value != blank -%}
			
			{%- assign custom_line_properties = '' -%}
			{%- assign custom_line_properties_header = '' -%}
			{%- assign required_custom_line_properties = '' -%}
			{%- assign typeFaceList = '' -%}
			
			{%- for custom_line_property in product.metafields.custom.custom_line_item_properties.value -%}
				{%- capture custom_line_property_html -%}
					
					{%- assign drawerID = custom_line_property.system.id | append: '-drawer' -%}
					{%- assign metaobject = custom_line_property.guide.value -%}
					{%- assign guideButton = '' -%}
				
					{%- if metaobject != blank -%}
						{%- capture additionalDrawerHtml -%}
						  	{%- render 'additional-drawer', 
								drawerID: drawerID, 
								drawerTitle: '', 
								drawerContent: '', 
								drawerFooterContent: '',
								metaobject: metaobject,
								option: option
							-%}
						{%- endcapture -%}

						{%- assign additionalDrawersHtml = additionalDrawersHtml | append: additionalDrawerHtml -%}
					
						{%- capture guideButton -%}
							{%- if additionalDrawerHtml != blank -%}
								<div class="Link Link--tertiary Link--underline" data-action="open-drawer" data-drawer-id="{{ drawerID }}" aria-label="{{ metaobject.link_title }}">{{ metaobject.link_title }}</div>
							{%- endif -%}		
						{%- endcapture -%}
					{%- endif -%}
				
	                {%- case custom_line_property.system.type -%}
						
						{%- when 'product_custom_line_date' -%}
							{%- assign additional_price_variant = custom_line_property.additional_price_variant.value -%}
							
							{%- capture custom_line_settings -%}
							{
							  "selector_id": "selectorId_{{ custom_line_property.system.id }}",
							  "price": {{ additional_price_variant.price | json }}
							}
							{%- endcapture -%}
							
							<div id="customLineProperty_{{ custom_line_property.system.id }}" class="customLineProperty_Date customLineProperty--optional" data-custom-line-settings='{{ custom_line_settings }}'>
								<div class="ProductForm__Option ProductForm__Option--labelled">
									<div class="Grid">
										<div class="Grid__Cell {% if custom_line_property.required.value or custom_line_property.group.value == false %}2/3--lap-and-up{% endif %}">
											{%- if custom_line_property.description.value != blank or custom_line_property.more_info.value -%}
												<div class="ProductForm__MoreInfo">
													{%- if custom_line_property.description.value != blank -%}
														{{ custom_line_property.description | metafield_tag }}
													{%- endif -%}
													
													{%- if custom_line_property.more_info.value != blank -%}
														{%- assign metaobject = custom_line_property.more_info.value -%}
														{%- assign drawerID = custom_line_property.system.id | append: '-' | append: metaobject.system.id | append: '-drawer' -%}
														{%- if metaobject != blank -%}
															{%- capture additionalDrawerHtml -%}
															  	{%- render 'additional-drawer', 
																	drawerID: drawerID, 
																	drawerTitle: '', 
																	drawerContent: '', 
																	drawerFooterContent: '',
																	metaobject: metaobject
																-%}
															{%- endcapture -%}

															{%- assign additionalDrawersHtml = additionalDrawersHtml | append: additionalDrawerHtml -%}
					
															{%- if additionalDrawerHtml != blank -%}
																<div class="Link Link--tertiary Link--underline" data-action="open-drawer" data-drawer-id="{{ drawerID }}" aria-label="{{ metaobject.link_title }}">{{ metaobject.link_title }}</div>
															{%- endif -%}	
														{%- endif -%}	
													{%- endif -%}
												</div>
											{%- endif -%}
											
											<div class="ProductForm__LabelWrapper">
												<span class="ProductForm__Label {% if custom_line_property.required.value %}ProductForm__Label--required{% endif %}">
													{{ custom_line_property.sub_heading }} {{ custom_line_property.label }}: 
										
													{% if additional_price_variant != blank %}
														<span class="ProductMeta__Price Price u-h6">
															{%- if settings.currency_code_enabled -%}
											                  {%- capture formatted_min_price -%}{{ additional_price_variant.price | money_with_currency | remove: '.00' }}{%- endcapture -%}
											                {%- else -%}
											                  {%- capture formatted_min_price -%}{{ additional_price_variant.price | money | remove: '.00' }}{%- endcapture -%}
											                {%- endif -%}
										
												            ({{ formatted_min_price }})
														</span>
													{% endif %}
												</span>
					
												{%- if guideButton != blank -%}
													<div>
														{{ guideButton }}
													</div>
												{%- endif -%}
											</div>
										</div>
									</div>
									
									<div class="ProductForm__Grid Grid">
										<div class="Grid__Cell 2/3--lap-and-up">
									        <div class="Form__Group">
												<div class="Form__Item">
													<input 
														type="date" 
														class="Form__Input"
														name="properties[{{ custom_line_property.sub_heading }} {{ custom_line_property.label }}]" 
														aria-label="{{ custom_line_property.sub_heading }} {{ custom_line_property.label }}" 
														{% if custom_line_property.required.value %}required{% endif %}
														data-custom-label="{{ custom_line_property.label }}" 
														{% if additional_price_variant != blank %}data-additional-fee-id="{{ additional_price_variant.id }}"{% endif %}
														>
												</div>
											</div>
										</div>
									</div>
								</div>
							</div>
							
						{%- when 'product_custom_line_text' -%}
							{%- assign additional_price_variant = custom_line_property.additional_price_variant.value -%}
							{%- assign numberTypeFaces = 0 -%}
							{%- assign defaultTypeFace = '' -%}
							{%- assign defaultTypeCase = '' -%}
							
							{%- capture typeFaces -%}
								{%- if custom_line_property.typeface.value != blank -%}
									<div class="ProductForm__Option ProductForm__Option--labelled ProductForm__Option--bordered">
										<span class="ProductForm__Label">
											Select Font:
										</span>
							
										<div class="Grid Grid--offsetBottom">
											{%- for typeface in custom_line_property.typeface.value -%}
												{%- assign fontFamily = typeface.display_name | split: '-' | first | handleize -%}
												{%- assign fontCase = typeface.sub_title | handleize -%}
												
												{%- if forloop.first -%}
													{%- assign defaultTypeFace = typeface.display_name | split: '-' | first | handleize -%}
													{%- assign defaultTypeCase = typeface.sub_title | handleize -%}
												{%- endif -%}
												
												{%- assign typeFaceList = typeFaceList | append: ', ' | append: fontFamily -%}
												
												{%- assign numberTypeFaces = numberTypeFaces | plus: 1 -%}
												<div class="Grid__Cell 3/12--phone 3/12--tablet-and-up 2/12--widescreen">
													
													<input id="option-{{ typeface.system.id }}-{{ custom_line_property.system.id }}-{{ forloop.index }}" class="ColorSwatch__Radio" type="radio" name="properties[{{ custom_line_property.sub_heading }} {{ custom_line_property.label }} Typeface]" value="{{ typeface.title }} {{ typeface.sub_title }}" data-font-family="{{ fontFamily }}" data-font-case="{{ fontCase }}" {% if forloop.first %}checked="checked"{% endif %}>
													<label for="option-{{ typeface.system.id }}-{{ custom_line_property.system.id }}-{{ forloop.index }}" class="TypeFaceSelector">
														{%- assign media = typeface.image.value -%}
														{%- if media != blank -%}
															<div class="TypeFaceSelector__Media">
																<div class="TypeFaceSelector__ImageWrapper AspectRatio AspectRatio--withFallback" style="padding-bottom: {{ 100.0 | divided_by: media.aspect_ratio }}%; --aspect-ratio: {{ media.aspect_ratio }};">
