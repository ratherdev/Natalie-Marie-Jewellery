																	{%- endif -%}
																	
																	<div class="AdditionalVariant__MetaInfo hidden-pocket hidden-lap">
																		<h3 class="Heading Heading--textFont Text--alignCenter u-h8">{{ additionalVariant.title }}</h3>
																		{%- if additionalVariant.metafields.custom.sub_title != blank -%}
																			<h4 class="Heading Heading--textFont Text--alignCenter Text--highlight u-h8" >{{ additionalVariant.metafields.custom.sub_title }}</h4>
																		{%- endif -%}
																	</div>
																	
																</div>
	
															</div>
														{%- endif -%}
													{%- endfor -%}
												{%- endcapture -%}
											
												<span class="ProductForm__Label {% if custom_line_property.required.value %}ProductForm__Label--required{% endif %}">
													Select {{ custom_line_property.label }}:
												</span>
											
												<div class="Grid Grid--offsetBottom Grid--2rows" style="--item-count: {{ itemCount | divided_by: 2.00 | ceil }};">
													{{ variantPicker }}
												</div>
												{% if custom_line_property.secondary_add_on_subheading != blank and secondaryVariantPicker %}
													<span class="ProductForm__Label {% if custom_line_property.required.value %}ProductForm__Label--required{% endif %}">
														Select {{ custom_line_property.secondary_add_on_subheading }}:
													</span>

													<div class="Grid Grid--offsetBottom Grid--2rows" style="--item-count: {{ itemCount | divided_by: 2.00 | ceil }};">
														{{ secondaryVariantPicker }}
													</div>
												{% endif %}
											</div>
										</birthstone-selector>
									</div>
									<scroll-bar scroll-direction="horizontal" aria-controls="scroll-{{ custom_line_property.system.id }}" class="custom-scroll-bar hidden-lap-and-up fadeIn">
										<button type="button" style="--item-count: {{ itemCount }};" class="custom-scroll-bar-slider"></button>
									</scroll-bar>
									<scroll-bar scroll-direction="vertical" aria-controls="scroll-{{ custom_line_property.system.id }}" class="custom-scroll-bar hidden-pocket fadeIn">
										<button type="button" style="--item-count: {{ itemCount }};" class="custom-scroll-bar-slider"></button>
									</scroll-bar>
								</div>
							</div>
							
					{%- endcase -%}
				{%- endcapture -%}
				
				{%- if custom_line_property.required.value or custom_line_property.group.value == false -%}
					{%- assign required_custom_line_properties = required_custom_line_properties | append: custom_line_property_html -%}
				{%- else -%}
					{%- capture custom_line_property_header_html -%}
						<div class="Grid__Cell Grid__Cell--expand 1/4">
							<div class="CustomLineProperties_Item" data-action="toggle-content" data-toggle-id="customLineProperty_{{ custom_line_property.system.id }}">
								<div class="Text--alignLeft">
									<span class="Heading Heading--textFont u-h7">{{ custom_line_property.label }}</span>
									<span class="Heading Heading--textFont u-h7">{{ custom_line_property.sub_heading }}</span>
								</div>
								<div class="Text--alignRight">
									<span id="selectorId_{{ custom_line_property.system.id }}__checkmark" class="Heading Heading--textFont u-h7">{% render 'icon' with 'checkmark' %}</span>
									<span id="selectorId_{{ custom_line_property.system.id }}__price" class="Heading Heading--textFont u-h7"></span>
								</div>
							</div>
						</div>
					{%- endcapture -%}
					{%- assign custom_line_properties_header = custom_line_properties_header | append: custom_line_property_header_html -%}
					{%- assign custom_line_properties = custom_line_properties | append: custom_line_property_html -%}
				{%- endif -%}
				
			{%- endfor -%}
			
			{%- if required_custom_line_properties != blank -%}
				{{ required_custom_line_properties }}
			{%- endif -%}
			
			{%- if custom_line_properties != blank -%}
				<div class="ProductForm__Option">
					<span class="ProductForm__Label">
						{{- 'product.form.optional_customisations' | t -}}
					</span>
					
					<div class="Grid CustomLineProperties_Header">
						{{ custom_line_properties_header }}
					</div>
					
					<div class="CustomLinePropertiesWrapper">
						<div class="CustomLineProperties">
							{{ custom_line_properties }}
						</div>
					</div>
					
				</div>
			{%- endif -%}
		{%- endif -%}
		
		<div class="no-js ProductForm__Option">
			<div class="Select Select--primary">
				{%- render 'icon' with 'select-arrow' -%}

				<select id="product-select-{{ product.id }}" name="id" title="Variant">
					{%- for variant in product.variants -%}
						<option {% if variant == selected_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %} value="{{ variant.id }}" data-sku="{{ variant.sku }}">{{ variant.title }} - {{ variant.price | money }}</option>
					{%- endfor -%}
				</select>
			</div>
		</div>
	{%- else -%}
		<input type="hidden" name="id" data-sku="{{ selected_variant.sku }}" value="{{ selected_variant.id }}">
	{%- endunless -%}
</div>

{%- if typeFaceList != blank -%}
	{%- assign typeFaceList = typeFaceList | remove_first: ", " | split: ', ' | unique -%}
	<style>
	{%- for typeFace in typeFaceList -%}
		{%- if typeFace != 'baskerville' and typeFace != 'arial' and typeFace != 'opensans' -%}
			{%- assign typeFaceWoff2 = typeFace | append: '.woff2' -%}
			{%- assign typeFaceWoff = typeFace | append: '.woff' -%}
			@font-face {
			    font-family: '{{ typeFace }}';
			    src: url({{ typeFaceWoff2 | file_url }}) format('woff2'),
			         url({{ typeFaceWoff | file_url }}) format('woff');
			    font-weight: normal;
			    font-style: normal;
			}
		{%- endif -%}
	{%- endfor -%}
	</style>
{%- endif -%}

{%- comment -%}
--------------------------------------------------------------------------------------------------------------------
OFF SCREEN ELEMENTS

Implementation note: in the past (with "include") we could accumulate the data and output it outside the snippet
itself. However with the new "render" tag, everything that is captured inside cannot be used outside the snippet
itself. As a consequence we are moving them in JavaScript. This allows to make sure that those elements are upper
in the DOM tree, and do not show below the content
--------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<div class="Product__OffScreen">
	{{- product_popovers -}}
	{%- if additionalDrawersHtml != blank -%}
		{{ additionalDrawersHtml }}
	{%- endif -%}
</div>