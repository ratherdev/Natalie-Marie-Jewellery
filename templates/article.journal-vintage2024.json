ocket":"1\/2","text_align":"center","subheading":"","title":"","description":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"text_with_media_cqnaAx":{"type":"text-with-media","blocks":{"image_qqnbae":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/1_01b73639-fd79-4854-9caf-667729240512.gif"}}},"block_order":["image_qqnbae"],"settings":{"remove_spacing_top":true,"remove_spacing_bottom":false,"enable_newsletter_subscribe":false,"klaviyo_form_id":"","media_position":"left","media_width":"6","content_position":"middleLeft","subheading":"","title":"","description":"<p>\"There is an interesting observation made in a piece published by the Victoria & Albert Museum in London, I found this exert particularly inspiring “These designs [Rococo] were largely intended for craftspeople and designers and were hugely influential in disseminating the Rococo style. Rather than copying the entire design, woodcarvers would mine them for inspiration, cutting them up and adding their own ideas.” I felt that this summarised so succinctly what we are trying to achieve in our Yesterday, Today collection. Drawing upon the beauty of artisans past to celebrate craftsmanship, design and jewellery through the ages.\" <\/p><p><br\/>- Shona, Head Designer. <\/p>","colour_style":"dark","button_1_text":"","button_1_link":"","button_style":"underline"}},"8f813602-ae9e-40c9-8baa-c4faf4dcb985":{"type":"content-slider","blocks":{"a3eaf62c-e1ff-49c5-8e62-1c2bb5d87619":{"type":"collection","settings":{"title":"<p><strong>Collection<\/strong><\/p>","collection":"vintage","show_product_info":true,"show_vendor":false,"show_color_swatch":true}}},"block_order":["a3eaf62c-e1ff-49c5-8e62-1c2bb5d87619"],"settings":{"enable_light":false,"grid_items_count":8,"enable_natual_scroll":false,"subheading":"<p><strong>Vintage<\/strong><\/p>","title":"<p>Step Back in <em>Time<\/em><\/p>","description":"<p>Vintage holds a special place in the heart of our founder, Natalie Fitch, in the DNA of our own designs, and in our pursuit of a more sustainable, circular jewellery economy. Now, we’re honoured to share this love with you.<\/p>","text_position":"left","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"main":{"type":"main-article","settings":{"show_article_image":false,"show_article_header":false,"show_article_content":false,"show_large":false,"show_category":false,"show_author":false,"show_share_buttons":false,"show_prev_next":true}}},"order":["ec32b834-e4e2-4e87-8392-6d45f7b82d33","f2c7e461-17b5-4ac9-b3b5-cc2870417eb5","fe4a59da-74f2-4522-93d1-709dd4b43c45","22942553-01da-4697-89ac-f500b502883f","text_with_media_cqnaAx","8f813602-ae9e-40c9-8baa-c4faf4dcb985","main"]}