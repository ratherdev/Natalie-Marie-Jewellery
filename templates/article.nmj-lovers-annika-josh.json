    "800eebd7-962e-4fa6-bc5d-8b818a1ba455": {
      "type": "content-list",
      "blocks": {
        "template--16177341137065__800eebd7-962e-4fa6-bc5d-8b818a1ba455-image-1": {
          "type": "image",
          "settings": {
            "apply_overlay": false,
            "devices": "mobile_desktop",
            "content_position": "underLeft",
            "subheading": "",
            "title": "",
            "description": "<p><strong>What is something that has surprised you about marriage – perhaps a misconception proven wrong, or an assumption proven right?</strong></p><p>The assumption that marriage helps you feel even closer and reinforces that you are a team was proven right. There may be the notion that marriage changes things, however, we had been together for several years and through many seasons already, so marriage did not change anything other than connecting us even more.</p><p><strong>What is one of your favourite moments from your special day?</strong></p><p>Untraditional, but spending a slow morning together before parting ways to get ready for our ceremony. It only built up the excitement and love we have for each other even more, reinforcing the life we want to live together and appreciating the small things.</p>",
            "description_mobile": "<p><strong>What is something that has surprised you about marriage – perhaps a misconception proven wrong, or an assumption proven right?</strong></p><p>The assumption that marriage helps you feel even closer and reinforces that you are a team was proven right. There may be the notion that marriage changes things, however, we had been together for several years and through many seasons already, so marriage did not change anything other than connecting us even more.</p><p><strong>What is one of your favourite moments from your special day?</strong></p><p>Untraditional, but spending a slow morning together before parting ways to get ready for our ceremony. It only built up the excitement and love we have for each other even more, reinforcing the life we want to live together and appreciating the small things.</p>",
            "colour_style": "dark",
