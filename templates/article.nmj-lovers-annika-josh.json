        "remove_spacing_bottom": true,
        "enable_newsletter_subscribe": false,
        "klaviyo_form_id": "",
        "media_position": "right",
        "media_position_mobile": "bottom",
        "media_width": "7",
        "content_position": "middleLeft",
        "subheading": "",
        "title": "<h3>“We are lucky in that the ways we have changed and grown <em>only brought us closer</em>.”</h3>",
        "description": "",
        "colour_style": "dark",
        "button_1_text": "",
