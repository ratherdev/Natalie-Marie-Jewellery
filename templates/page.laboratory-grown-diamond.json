      "settings": {
        "remove_spacing_top": true,
        "remove_spacing_bottom": true,
        "enable_newsletter_subscribe": false,
        "klaviyo_form_id": "",
        "media_position": "right",
        "media_position_mobile": "bottom",
        "media_width": "6",
        "content_position": "topLeftSticky",
        "subheading": "",
        "title": "<p><em>Certification & Quality</em></p>",
        "description": "<p>All of our laboratory grown diamonds <strong>above 0.30ct </strong>are independently certified by leading gemological institutes, including:</p><ul><li><strong>GIA (Gemological Institute of America)</strong></li><li><strong>IGI (International Gemological Institute)</strong></li><li><strong>GCAL (Gem Certification & Assurance Lab)</strong></li></ul><p>Each stone features:<br/></p><ul><li>A unique certification number</li><li>Detailed grading across cut, colour, clarity and carat</li></ul>",
        "colour_style": "dark",
        "button_1_text": "",
        "button_1_link": "",
        "button_style": "underline"
      }
    },
