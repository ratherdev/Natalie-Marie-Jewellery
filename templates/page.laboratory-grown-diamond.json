        "klaviyo_form_id": "",
        "media_position": "right",
        "media_position_mobile": "bottom",
        "media_width": "6",
        "content_position": "topLeftSticky",
        "subheading": "",
        "title": "<p><em>Ethical Considerations</em></p>",
        "description": "<p>Reliable, published data around the social impact of laboratory grown diamonds is still developing.</p><p><br/>Areas of uncertainty include:</p><ul><li>Employment conditions in manufacturing facilities</li><li>Human rights standards across production regions</li><li>Contributions to local communities and economies<br/></li></ul><p>Unlike some mined diamond industries, laboratory grown production does not always have established frameworks for community investment or traceable impact.<br/></p>",
        "colour_style": "dark",
        "button_1_text": "",
        "button_1_link": "",
        "button_style": "underline"
      }
    },
    "text_with_media_tG8qCR": {
      "type": "text-with-media",
      "blocks": {
