r":["template--16109996736681__997372c7-0ab6-400b-ad30-a2d5a1c0d4d5-168004398277d4c221-0"],"settings":{"enable_dark":false,"subheading":"<p><strong>A passion to create<\/strong><\/p>","title":"<p>Our <em>story<\/em><\/p>","description":"<p>Natalie Marie Jewellery was born out of a passion for the craft. At the core of what we do is a dedication to traditional, superior craftsmanship; a focus on sustainability and high quality materials; and a commitment to our own unique style. <br\/><br\/>We believe that jewellery is both art and an investment and as such, take pride in every piece we create at NMJ. We make each piece to order – a conscious decision that allows us to minimise our footprint on the environment and gives us the opportunity to connect with clients on a deeply personal level. Our clients, and the part that we have to play in their story, is at the heart of everything we do. <br\/><br\/>Our designs combine minimal styling with traditional detailing and embellishments - a unification of our jewellers’ own design visions - which results in an aesthetic that speaks its own distinctive language.<\/p>","feature_text":"<p>Natalie Marie Jewellery offers a <em>non traditional jewellery experience<\/em>, creating a relaxed, comfortable, holistic approach  with a focus on <em>sentiment and connection<\/em>.<\/p>","colour_style":"dark","button_1_text":"","button_1_link":"","button_style":"underline"}},"75882962-18f4-47a2-adca-a3c0f9947ea9":{"type":"content-list","blocks":{"template--16109996736681__75882962-18f4-47a2-adca-a3c0f9947ea9-16805017952ca5d298-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/81044ce53ce17d658c056337eae59720.jpg","apply_overlay":false,"devices":"mobile_desktop","content_position":"underLeft","subheading":"","title":"","description":"","description_mobile":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"template--16109996736681__75882962-18f4-47a2-adca-a3c0f9947ea9-16805017952ca5d298-1":{"type":"image","disabled":true,"settings":{"apply_overlay":false,"devices":"mobile_desktop","content_position":"underLeft","subheading":"<p>Sub-heading<\/p>","title":"<p>Heading<\/p>","description":"","description_mobile":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"template--16109996736681__75882962-18f4-47a2-adca-a3c0f9947ea9-16805017952ca5d298-2":{"type":"image","disabled":true,"settings":{"apply_overlay":false,"devices":"mobile_desktop","content_position":"underLeft","subheading":"<p>Sub-heading<\/p>","title":"<p>Heading<\/p>","description":"","description_mobile":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}}},"block_order":["template--16109996736681__75882962-18f4-47a2-adca-a3c0f9947ea9-16805017952ca5d298-0","template--16109996736681__75882962-18f4-47a2-adca-a3c0f9947ea9-16805017952ca5d298-1","template--16109996736681__75882962-18f4-47a2-adca-a3c0f9947ea9-16805017952ca5d298-2"],"settings":{"grid_items_count":3,"grid_items_count_pocket":"1\/2","subheading":"","title":"","description":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"90584860-62b1-4328-946f-aeca05899212":{"type":"text-with-media","blocks":{"template--16109996736681__90584860-62b1-4328-946f-aeca05899212-16800441979069c86d-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/aa88797241a96e0c95470dd34d6d5d03.jpg"}}},"block_order":["template--16109996736681__90584860-62b1-4328-946f-aeca05899212-16800441979069c86d-0"],"settings":{"remove_spacing_top":true,"remove_spacing_bottom":false,"enable_newsletter_subscribe":false,"klaviyo_form_id":"","media_position":"left","media_width":"7","content_position":"topLeftSticky","subheading":"<p><strong>MEET THE FOUNDER<\/strong><\/p>","title":"<p>About <em>Natalie<\/em><\/p>","description":"<p>Born and raised in Southern England, Natalie Fitch moved to Australia at twenty, having travelled extensively after graduating school. Having always been creative and tactile, Natalie completed a Bachelor of Visual Arts at Sydney University, where she majored in Jewellery and Object, launching her namesake label immediately afterwards.<br\/><br\/>Crafting jewellery for Natalie is more than just creating an object, it’s the opportunity to create something that is symbolic and significant – “wearable treasures that act as tangible expressions of love or sentiment”, she says.Natalie’s deep and personal belief that everything and everyone is connected by love is evident within the brand, the handcrafted jewels she makes and the culture she has created within her team. She hopes that those who purchase NMJ have “a deeply connective experience which satisfies the experience of storytelling and craftmanship”.<br\/><br\/>Natalie and her husband Daniel now run Natalie Marie Jewellery collaboratively, with the support of their talented and dedicated team. Parents to two beautiful daughters, the duo maintain a strong connection to the day to day running of every aspect of the business, deeply involved and immersed in the family business they have proudly built. <\/p>","colour_style":"dark","button_1_text":"","button_1_link":"","button_style":"underline"}},"68966aab-f1bf-4a63-adbd-50f2936e901e":{"type":"content-slider","blocks":{"b27fade7-a67c-45d0-ae74-33141c566912":{"type":"blog","settings":{"title":"<p><strong>Blog<\/strong><\/p>","blog":"news","show_category":true,"show_exerpt":true}}},"block_order":["b27fade7-a67c-45d0-ae74-33141c566912"],"settings":{"enable_light":false,"grid_items_count":20,"enable_natual_scroll":true,"subheading":"<p><strong>BLOG<\/strong><\/p>","title":"<p>The <em>Journal<\/em><\/p>","description":"<p>There is nothing more important to us than the people who make up our community and our team. Here, we share their insights, musings and reflections – so you can stay up-to date with our progress and journey as a company.<\/p>","text_position":"left","colour_style":"dark","button_1_text":"View All","button_1_link":"shopify:\/\/blogs\/news","button_2_text":"","button_2_link":"","button_style":"underline"}},"1680065008faa6d8e1":{"type":"apps","blocks":{"5324be2c-dde7-4b70-803a-fb0558845666":{"type":"shopify:\/\/apps\/instafeed\/blocks\/app-block\/c447db20-095d-4a10-9725-b5977662c9d5","settings":{"html_area":""}}},"block_order":["5324be2c-dde7-4b70-803a-fb0558845666"],"settings":{"include_margins":true,"subheading":"<p><strong>Instagram<\/strong><\/p>","title":"<p>Shop our <em>feed<\/em><\/p>","description":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}}},"order":["main","c94113ea-ad2b-4275-9418-8134b53d96d7","997372c7-0ab6-400b-ad30-a2d5a1c0d4d5","75882962-18f4-47a2-adca-a3c0f9947ea9","90584860-62b1-4328-946f-aeca05899212","68966aab-f1bf-4a63-adbd-50f2936e901e","1680065008faa6d8e1"]}