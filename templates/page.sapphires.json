      "settings": {
        "remove_spacing_top": true,
        "remove_spacing_bottom": true,
        "enable_newsletter_subscribe": false,
        "klaviyo_form_id": "",
        "media_position": "right",
        "media_position_mobile": "bottom",
        "media_width": "6",
        "content_position": "topLeftSticky",
        "subheading": "",
        "title": "<p><em>Durability & Everyday Wear</em></p>",
        "description": "<p>Sapphires are one of the most durable gemstones available, making them well suited to everyday wear.</p><p>However, like all fine jewellery, they should be worn with care:</p><ul><li>Avoid hard knocks or impact</li><li>Remove during heavy activity</li><li>Clean gently and regularly</li></ul><p>With the right care, a sapphire piece can become a modern heirloom, passed down through generations.</p>",
        "colour_style": "dark",
        "button_1_text": "",
        "button_1_link": "",
        "button_style": "underline"
      }
    },
