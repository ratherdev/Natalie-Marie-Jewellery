:true,"show_if_outside_limits":false,"product":"{{product}}"}},"description":{"type":"description","settings":{"display_mode":"default"}},"88aae3ed-df89-4ee9-9218-0a9c53fe04ee":{"type":"rich_text","settings":{"rich_text":"<p>Feeling inspired? Speak to us about designing your own bespoke piece through the buttons above.<\/p>","display_mode":"default"}},"2127c758-a216-4fdd-9428-0d1686d80104":{"type":"footer_button_set","settings":{"drawer_title":"","button_1_text":"Materials & Dimensions","button_1_content":"<h3>Materials <em>& Dimensions<\/em><br\/><\/h3><p>{{ product.metafields.custom.materials_dimensions | metafield_tag }}<\/p>","button_2_text":"Production & Shipping","button_2_content":"<h3>Production <em>& Shipping<\/em><\/h3><h3><\/h3><p>This piece is handmade to order. Please allow approximately 6-8 weeks for the production of this piece.<br\/><br\/>If the piece has optional customisation offerings, please refer to the estimated dispatch time presented by the add to cart button as this may affect the lead time.<br\/><br\/><strong>SHIPPING<\/strong><br\/>We ship globally, using express priority shipping methods to ensure traceability and insurance, and offer complimentary worldwide shipping on all orders over $1,000 AUD.<br\/><br\/>Duties and taxes levied by the recipient country are the responsibility of the customer.<br\/><br\/>For more details on shipping and delivery .<br\/><strong><br\/>INSURANCE<\/strong><br\/>We partner with Centrestone Jewellery Insurance. We recommend learning more about their service and considering insurance on your treasured pieces. For more details, contact our team <br\/><\/p>","button_3_text":"Crafting Location","button_3_content":"<h3>Crafting <em>Location<\/em><\/h3><p><br\/>NMJ pieces are mindfully handcrafted, predominantly in our in house Sydney studio. We pride ourselves on creating not only a safe and healthy working environment for our team of jewellers, but also a nurturing and supportive platform for their growth as jewellers and professionals in their field.<br\/><br\/>We encourage and support skill development and personal growth with a focus on creating a positive and enjoyable workspace. Using hand tools as opposed to heavy machinery lessens our carbon footprint, while selecting non toxic compounds for use in the studio reduces our environmental impact. <\/p><p><br\/>We have recently partnered with accredited facilities both in Sydney and overseas to facilitate the expansion of our production to meet a growing demand, while we work on building out our own team to facilitate this in house. You can read more about our manufacturing avenues <a href=\"https:\/\/www.nataliemariejewellery.com\/pages\/our-makers\" target=\"_blank\" title=\"Our Makers\">here<strong>.<\/strong><\/a><\/p>","display_mode":"default"}},"14f4f42a-06eb-4c02-b7c7-de1c60bcec03":{"type":"liquid","disabled":true,"settings":{"liquid":"","display_mode":"default"}}},"block_order":["product_meta","variant_selector","62b4d10b-c51e-49dc-9a1d-47f01b3adb57","1b4339d0-1da8-4c8f-a0a4-c9548209c917","37de9c99-4b54-4a6d-a2d7-8a96815c34f4","afterpay_on_site_messaging_payments_messaging_PyzhMU","description","88aae3ed-df89-4ee9-9218-0a9c53fe04ee","2127c758-a216-4fdd-9428-0d1686d80104","14f4f42a-06eb-4c02-b7c7-de1c60bcec03"],"settings":{"stack_images":true,"sandwich_images":false,"enable_tagling":true,"enable_price":true,"show_thumbnails":true,"enable_image_zoom":true,"enable_video_looping":false}},"07b60383-6739-4700-a830-ed3dfaa9803d":{"type":"styled-with","blocks":{"template--16118523232425__07b60383-6739-4700-a830-ed3dfaa9803d-style-1":{"type":"style","repeater":"{{ product.metafields.custom.style_by.value }}","settings":{"image":"{{ block.repeater.style_with_media.value }}","video":"{{ block.repeater.style_with_media.value }}","autoplay":true,"loop":true,"style_tag":"{{ block.repeater.instagram_tag.value }}","link":"{{ block.repeater.style_with_tag_link.value }}","description":"{{ block.repeater.style_with_paragraph | metaf