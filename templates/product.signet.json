r_limit":true,"show_upper_limit":true,"show_if_outside_limits":false,"product":"{{product}}"}},"description":{"type":"description","settings":{"display_mode":"default"}},"2127c758-a216-4fdd-9428-0d1686d80104":{"type":"footer_button_set","settings":{"drawer_title":"<p><strong>Product Information<\/strong><\/p>","button_1_text":"Materials & Dimensions","button_1_content":"<h3>Materials <em>& Dimensions<\/em><br\/><\/h3><p>{{ product.metafields.custom.materials_dimensions | metafield_tag }}<\/p><p>{{ product.metafields.custom.personalisation_info | metafield_tag }}<\/p>","button_2_text":"Production & Shipping","button_2_content":"<h3>Production <em>& Shipping<\/em><\/h3><p>This piece is handmade to order. Please allow approximately {{ product.metafields.custom.dispatch.value }} for the production of this piece.<br\/><br\/>If the piece has optional customisation offerings, please refer to the estimated dispatch time presented by the add to cart button as this may affect the lead time. <br\/><br\/>We ship globally, using express priority shipping methods to ensure traceability and insurance, and offer complimentary worldwide shipping on all orders over $1,000 AUD.<br\/><br\/>Duties and taxes levied by the recipient country are the responsibility of the customer.<br\/> <br\/>For more details on shipping and delivery <a href=\"\/pages\/shipping-production\" target=\"_blank\" title=\"Shipping and Production\">here<\/a>.<\/p><p><\/p><p><strong>INSURANCE<\/strong><br\/>We partner with Centrestone Jewellery Insurance. We recommend learning more about their service and considering insurance on your treasured pieces. For more details, contact our team <a href=\"https:\/\/www.nataliemariejewellery.com\/pages\/contact\">here.<\/a><br\/><br\/><br\/><\/p>","button_3_text":"Crafting Location","button_3_content":"<h3>Crafting <em>Location<\/em><\/h3><p>NMJ pieces are mindfully handcrafted, predominantly in our in house Sydney studio. We pride ourselves on creating not only a safe and healthy working environment for our team of jewellers, but also a nurturing and supportive platform for their growth as jewellers and professionals in their field.<\/p><p>We encourage and support skill development and personal growth with a focus on creating a positive and enjoyable workspace. Using hand tools as opposed to heavy machinery lessens our carbon footprint, while selecting non toxic compounds for use in the studio reduces our environmental impact. <\/p><p>We have recently partnered with accredited facilities both in Sydney and overseas to facilitate the expansion of our production to meet a growing demand, while we work on building out our own team to facilitate this in house. You can read more about our manufacturing avenues <a href=\"https:\/\/www.nataliemariejewellery.com\/pages\/our-makers\" target=\"_blank\" title=\"Our Makers\">here<strong>.<\/strong><\/a><\/p>","display_mode":"default"}}},"block_order":["product_meta","variant_selector","1b4339d0-1da8-4c8f-a0a4-c9548209c917","653620fe-8d1b-4464-ac42-e9bb8988e6b7","buy_buttons","276920e0-adc7-4a92-82ca-5370a9703abb","afterpay_on_site_messaging_payments_messaging_VjX3TG","description","2127c758-a216-4fdd-9428-0d1686d80104"],"settings":{"stack_images":true,"sandwich_images":false,"enable_tagling":true,"enable_price":true,"show_thumbnails":true,"enable_image_zoom":true,"enable_video_looping":false}},"d10b5870-8275-4970-829c-9af5f24be671":{"type":"styled-with","blocks":{"template--16203639783593__d10b5870-8275-4970-829c-9af5f24be671-style-1":{"type":"style","repeater":"{{ product.metafields.custom.style_by.value }}","settings":{"image":"{{ block.repeater.style_with_media.value }}","video":"{{ block.repeater.style_with_media.value }}","autoplay":true,"loop":true,"style_tag":"{{ block.repeater.instagram_tag.value }}","link":"{{ block.repeater.style_with_tag_link.value }}","description":"{{ block.repeater.style_with_paragraph | metafield_tag }}","title":"","products":"{{ block.repeater.style_with_product.value }}"}}},"block_order":["template--16203639783593__d10b5870-8275-4970-829c-9af5f24be671-style-1"],"settings":{"separate_section_with_border":true,"enable_dark":false,"subheading":"","title":"<p>Styled <em>By<\/em><\/p>","description":"<p>See how the {{ product.title }} is styled to get inspiration on how to create your perfect stack.<\/p>","feature_text":"","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"9d52ce25-f050-44e7-874d-70597692f5dd":{"type":"content-slider","blocks":{"b65acb15-5c5d-4d96-9794-e3e11769da6b":{"type":"complementary","settings":{"contentProduct":"{{ product }}","use_first_cart_item":false,"title":"<p><strong>Perfectly Paired<\/strong><\/p>","show_product_info":true,"show_vendor":false,"show_color_swatch":true}},"bf2da388-9cf9-4673-957d-9c2521ac348f":{"type":"related","settings":{"contentProduct":"{{ product }}","use_first_cart_item":false,"title":"<p><strong>You May Like<\/strong><\/p>","show_product_info":true,"show_vendor":false,"show_color_swatch":true}},"4aba9b05-f9c0-40db-8897-e53803ce4297":{"type":"collection","settings":{"title":"<p><strong>Most Loved<\/strong><\/p>","collection":"most-loved","show_product_info":true,"show_vendor":false,"show_color_swatch":true}},"93faab48-3bfd-4b72-8e25-d026d7a3c9a2":{"type":"recently","settings":{"title":"<p><strong>Recently Viewed<\/strong><\/p>","show_product_info":true,"show_vendor":false,"show_color_swatch":true}}},"block_order":["b65acb15-5c5d-4d96-9794-e3e11769da6b","bf2da388-9cf9-4673-957d-9c2521ac348f","4aba9b05-f9c0-40db-8897-e53803ce4297","93faab48-3bfd-4b72-8e25-d026d7a3c9a2"],"settings":{"enable_light":false,"grid_items_count":8,"enable_natual_scroll":true,"subheading":"","title":"<p>Curated <em>for you<\/em><\/p>","description":"","text_position":"top","colour_style":"dark","button_1_text":"","button_1_link":"","button_2_text":"","button_2_link":"","button_style":"underline"}},"bae4219e-a8d2-418b-a9d2-ac68d615b624":{"type":"text-with-media","blocks":{"9697eead-ba51-4df1-aa9b-b1584b228ee3":{"type":"video","settings":{"video":"shopify:\/\/files\/videos\/4-Signet PLP and PDPs_1_1.mp4","video_url":"","video_size":"1920x1080","autoplay":true,"loop":true}}},"block_order":["9697eead-ba51-4df1-aa9b-b1584b228ee3"],"settings":{"remove_spacing_top":true,"remove_spacing_bottom":true,"enable_newsletter_subscribe":false,"klaviyo_form_id":"","media_position":"right","media_position_mobile":"bottom","media_width":"6","content_position":"topLeftSticky","subheading":"","title":"<p>Celebrate <em>You<\/em><\/p>","description":"<p>Adding personal touches to the pieces we create is something we are deeply passionate about. We have always felt that pieces you invest in should feel like an extension of you and your unique story. For centuries, signets were considered equivalent to fingerprints; so unique to the individual that they became a part of their identity. We invite you to discover the layers of possibility for potential personalisation of our signet styles, enabling you to create a piece which is truly yours.<br\/><\/p><p>From gemstone additions and hand engraving opportunities, to varied profiles and finishes; discover how to add layers of personal touches to our classic signet collections. Honour the sentiment of the traditional signet ring and create a piece which celebrates you and your story.<\/p>","colour_style":"dark","button_1_text":"","button_1_link":"","button_style":"underline"}},"5be79fed-adc4-463c-a6b7-09a47a72b75e":{"type":"text-with-media","blocks":{"template--16203639783593__5be79fed-adc4-463c-a6b7-09a47a72b75e-image-1":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Signet_Tile.jpg"}}},"block_order":["template--16203639783593__5be79fed-adc4-463c-a6b7-09a47a72b75e-image-1"],"settings":{"remove_spacing_top":true,"remove_spacing_bottom":true,"enable_newsletter_subscribe":false,"klaviyo_form_id":"","media_position":"left","media_position_mobile":"bottom","media_width":"6","content_position":"topLeftSticky","subheading":"","title":"<p>Where to <em>Begin<\/em><\/p>","description":"<p>1. Start by browsing our online collection of <a href=\"\/collections\/signets\" target=\"_blank\" title=\"Signets\">signets<\/a> and select your preferred metal, then choose between a polished, brushed, or matte finish.<\/p><p>2. Share secret messages and keep it deeply personal with an accent or hidden stone, available on a wide selection of our signets. Let your birthstone choice serve as a constant reminder of what you hold most dear; a wearable symbol of individuality, a celebration, memory, an ode to a loved one or a marker of time.<\/p><p>3. Imprint your (or a loved ones) initials into your precious talisman, keeping your beloved close at hand always. Dive into the beauty of hand engraving and include meaningful initials in unique fonts or hidden notes inside the band, available on a wide selection of signets.<\/p><p>Discover the traditional artform of hand engraving to take your personalisation journey further. Create your own custom engraving artwork; add a discreet message; include meaningful initials, symbols or a commemorative date. <\/p><p><a href=\"\/pages\/contact\" target=\"_blank\" title=\"Contact us\">Contact our team<\/a> to discuss further options. We would be honoured to bring your vision to life.<\/p>","colour_style":"dark","button_1_text":"","button_1_link":"","button_style":"underline"}},"047d8527-e48d-4c85-ba56-1aa48c4b98ba":{"type":"content-list","blocks":{"ed6eb3ec-7a30-434e-8f77-587de2bde476":{"type":"image","repeater":"{{ product.metafields.custom.usp.value }}","settings":{"image":"{{ block.repeater.main_image.value }}","apply_overlay":false,"devices":"mobile_desktop","content_position":"middleCenter","logo_image":"{{ block.repeater.icon.value }}","subheading":"{{ block.repeater.sub_heading | metafield_tag }}","title":"{{ block.repeater.title | metafield_tag }}","description":"{{ block.repeater.description | met