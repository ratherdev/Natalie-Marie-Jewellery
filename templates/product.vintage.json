":"","button_2_icon":"none","button_2_metaobject":"","button_style":"secondary","display_mode":"unavailable"}},"description":{"type":"description","settings":{"display_mode":"default"}},"2127c758-a216-4fdd-9428-0d1686d80104":{"type":"footer_button_set","settings":{"drawer_title":"<p><strong>Product Information<\/strong><\/p>","button_1_text":"Materials & Dimensions","button_1_content":"<h3>Materials <em>& Dimensions<\/em><br\/><\/h3><p>{{ product.metafields.custom.materials_dimensions | metafield_tag }}<\/p>{{ product.metafields.custom.info_link | metafield_tag }}","button_2_text":"Production & Shipping","button_2_content":"<h3>Production <em>& Shipping<\/em><\/h3><p>This piece is ready to ship and will be posted the next business day, unless a custom resize has been requested.<\/p><p>We ship globally, using express priority shipping methods to ensure traceability and insurance, and offer complimentary shipping on all one-of-a-kind orders. Duties and taxes levied by the recipient country are the responsibility of the customer.<br\/> <br\/>For more details on shipping and delivery <a href=\"\/pages\/shipping-production-info\" target=\"_blank\" title=\"Shipping & Production\">here<\/a>.<\/p><p><\/p><p><strong>INSURANCE<\/strong><br\/>We partner with Q-Report Jewellery Insurance. We recommend learning more about their service and considering insurance on your treasured pieces. For more details, view our insurance guide <a href=\"https:\/\/f.hubspotusercontent10.net\/hubfs\/5372915\/(QR)%20legal%20documents\/Q%20Report%20Policy%20-%2010%20March%202021.pdf\" target=\"_blank\" title=\"https:\/\/f.hubspotusercontent10.net\/hubfs\/5372915\/(QR)%20legal%20documents\/Q%20Report%20Policy%20-%2010%20March%202021.pdf\">here<\/a>.<br\/><br\/><br\/><\/p>","button_3_text":"Crafting Location","button_3_content":"<h3>Crafting <em>Location<\/em><\/h3><p>NMJ pieces are mindfully handcrafted, predominantly in our in house Sydney studio. We pride ourselves on creating not only a safe and healthy working environment for our team of jewellers, but also a nurturing and supportive platform for their growth as jewellers and professionals in their field.<\/p><p>We encourage and support skill development and personal growth with a focus on creating a positive and enjoyable workspace. Using hand tools as opposed to heavy machinery lessens our carbon footprint, while selecting non toxic compounds for use in the studio reduces our environmental impact. <\/p><p>We have recently partnered with accredited facilities both in Sydney and overseas to facilitate the expansion of our production to meet a growing demand, while we work on building out our own team to facilitate this in house. You can read more about our manufacturing avenues <a href=\"https:\/\/www.nataliemariejewellery.com\/pages\/our-makers\" target=\"_blank\" title=\"Our Makers\">here<strong>.<\/strong><\/a><\/p>","display_mode":"available"}},"00a8691e-03f7-4ac8-90bd-456c21d98fdc":{"type":"footer_button_set","settings":{"drawer_title":"<p><strong>Product Information<\/strong><\/p>","button_1_text":"Materials & Dimensions","button_1_content":"<h3>Materials <em>& Dimensions<\/em><br\/><\/h3><p>{{ product.metafields.custom.materials_dimensions | metafield_tag }}<\/p><p>{{ product.metafields.custom.info_link | metafield_tag }}<\/p>","button_2_text":"","button_2_content":"","button_3_text":"","button_3_content":"","display_mode":"unavailable"}}},"block_order":["product_meta","variant_selector","24eb2c6b-9782-425d-bfb4-c02a04f10022","1b4339d0-1da8-4c8f-a0a4-c9548209c917","buy_buttons","276920e0-adc7-4a92-82ca-5370a9703abb","2897abe7-f688-47a1-a7c9-172241e347d7","e942b690-e377-41b8-85b2-73f9db52c8ed","description","2127c758-a216-4fdd-9428-0d1686d80104","00a8691e-03f7-4ac8-90bd-456c21d98fdc"],"settings":{"stack_images":true,"enable_tagling":true,"enable_price":true,"show_thumbnails":true,"enable_image_zoom":true,"enable_video_looping":false}},"eee4994f-7e66-42d5-b0c2-be7537546bb9":{"type":"styled-with","blo